      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500;1,600&family=Inter:wght@300;400;500;600&display=swap');\n\n  :root {\n    --rose-dark: #8C4B5C;\n    --rose-main: #B37280;\n    --rose-light: #D9A5AE;\n    --beige-dark: #A68A6D;\n    --beige-main: #E8D9C8;\n    --beige-light: #F5EDE4;\n    --white: #FFFFFF;\n    --charcoal: #3A3235;\n    --gray-text: #6E6265;\n    --copper: #B5713D;\n  }\n\n  .font-serif { font-family: 'Playfair Display', serif; }\n  .font-sans { font-family: 'Inter', sans-serif; }\n\n  .lp-root { background-color: var(--beige-light); color: var(--charcoal); font-family: 'Inter', sans-serif; }\n\n  .link-underline { position: relative; }\n  .link-underline::after {\n    content: ''; position: absolute; left: 0; bottom: -4px; height: 1px; width: 100%;\n    background: currentColor; transform: scaleX(0); transform-origin: left; transition: transform .4s ease;\n  }\n  .link-underline:hover::after { transform: scaleX(1); }\n\n  .btn-rose:hover { background-color: var(--rose-main); }\n  .area-row:hover .area-title { color: var(--rose-dark); }\n  .area-row:hover .area-arrow { opacity: 1; transform: translateX(0); }\n</style>\n\n<div class=\"lp-root font-sans antialiased overflow-x-clip\" data-kid=\"1\">\n\n  \n  <header class=\"fixed top-0 inset-x-0 z-50 px-6 lg:px-10 pt-5\" data-kid=\"2\">\n    <nav class=\"mx-auto max-w-[1360px] flex items-center justify-between rounded-full border border-white/40 bg-white/55 backdrop-blur-md px-6 lg:px-8 py-3 shadow-[0_10px_40px_-18px_rgba(58,50,53,0.35)]\" data-kid=\"3\">\n      \n      <a href=\"index.html\" class=\"flex items-center gap-3 shrink-0\" data-kid=\"4\">\n        <span class=\"grid place-items-center h-9 w-9 rounded-full border border-[var(--copper)]/60 text-[var(--copper)] font-serif italic text-lg leading-none\" data-kid=\"5\">M</span>\n        <span class=\"leading-tight\" data-kid=\"6\">\n          <span class=\"block font-serif text-[17px] text-[var(--charcoal)] tracking-tight\" data-kid=\"7\">Morgado &amp; Asociados</span>\n          <span class=\"block text-[9px] uppercase tracking-[0.35em] text-[var(--copper)]\" data-kid=\"8\">Asesoría Legal · Chile</span>\n        </span>\n      </a>\n      \n      <ul class=\"hidden lg:flex items-center gap-9 text-[13px] tracking-wide text-[var(--charcoal)]/85\" data-kid=\"9\">\n        <li data-kid=\"10\"><a href=\"index.html\" class=\"link-underline text-[var(--rose-dark)] font-medium\" data-kid=\"11\">Inicio</a></li>\n        <li data-kid=\"12\"><a href=\"about.html\" class=\"link-underline\" data-kid=\"13\">Sobre Nosotros</a></li>\n        <li data-kid=\"14\"><a href=\"services.html\" class=\"link-underline\" data-kid=\"15\">Servicios</a></li>\n        <li data-kid=\"16\"><a href=\"contact.html\" class=\"link-underline\" data-kid=\"17\">Contacto</a></li>\n      </ul>\n      \n      <a href=\"contact.html\" class=\"btn-rose shrink-0 inline-flex items-center gap-2 rounded-full bg-[var(--rose-dark)] px-5 py-2.5 text-[13px] font-medium text-white transition-colors\" data-kid=\"18\">\n        <span class=\"h-1.5 w-1.5 rounded-full bg-[var(--rose-light)]\" data-kid=\"19\"></span>\n        Consulta Inicial\n      </a>\n    </nav>\n  </header>\n\n  \n  <section id=\"inicio\" class=\"relative\" data-kid=\"20\">\n    <div class=\"mx-auto max-w-[1440px] grid lg:grid-cols-[1.05fr_0.95fr] min-h-screen\" data-kid=\"21\">\n\n      \n      <div class=\"relative flex flex-col justify-center px-8 sm:px-14 lg:pl-24 lg:pr-16 pt-36 pb-16\" data-kid=\"22\">\n        <div class=\"max-w-xl\" data-kid=\"23\">\n          <div class=\"hero-eyebrow flex items-center gap-4 mb-8\" data-kid=\"24\">\n            <span class=\"h-px w-10 bg-[var(--copper)]\" data-kid=\"25\"></span>\n            <span class=\"text-[11px] uppercase tracking-[0.32em] text-[var(--copper)] font-medium\" data-kid=\"26\">Defensa y Asesoría Legal de Excelencia</span>\n          </div>\n\n          <h1 class=\"font-serif text-[var(--rose-dark)] leading-[1.02] text-[clamp(2.6rem,5vw,4.4rem)]\" data-kid=\"27\">\n            <span class=\"hero-line block italic font-semibold\" data-kid=\"28\">Protegemos su</span>\n            <span class=\"hero-line block italic font-semibold\" data-kid=\"29\">tranquilidad con</span>\n            <span class=\"hero-line block not-italic font-semibold text-[var(--charcoal)]\" data-kid=\"30\">estrategias jurídicas</span>\n            <span class=\"hero-line block italic font-semibold\" data-kid=\"31\">a la medida.</span>\n          </h1>\n\n          <p class=\"hero-sub mt-8 max-w-md text-[15.5px] leading-relaxed text-[var(--gray-text)]\" data-kid=\"32\">\n            Acompañamos a personas y empresas en cada etapa de su proceso legal, con criterio, cercanía y una trayectoria de más de dos décadas defendiendo lo que más importa.\n          </p>\n\n          <div class=\"hero-cta mt-10 flex flex-wrap items-center gap-7\" data-kid=\"33\">\n            <a href=\"contact.html\" class=\"btn-rose inline-flex items-center gap-2.5 rounded-full bg-[var(--rose-dark)] px-7 py-3.5 text-[14px] font-medium text-white transition-colors shadow-[0_16px_34px_-16px_rgba(140,75,92,0.9)]\" data-kid=\"34\">\n              Hablemos de su caso\n              <svg class=\"w-5 h-2.5\" viewBox=\"0 0 34 8\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.2\" data-kid=\"35\"><!-- stripped due to large size --></svg>\n            </a>\n            <a href=\"#servicios\" class=\"link-underline text-[14px] font-medium text-[var(--charcoal)]\" data-kid=\"38\">Ver áreas de práctica</a>\n          </div>\n        </div>\n\n        \n        <div class=\"hidden lg:flex absolute bottom-10 left-24 items-center gap-3 text-[11px] tracking-[0.25em] uppercase text-[var(--beige-dark)]\" data-kid=\"39\">\n          <span data-kid=\"40\">Est. 2003</span>\n          <span class=\"h-px w-8 bg-[var(--beige-dark)]/60\" data-kid=\"41\"></span>\n          <span data-kid=\"42\">Santiago · Chile</span>\n        </div>\n      </div>\n\n      \n      <div class=\"relative overflow-hidden min-h-[60vh] lg:min-h-screen\" data-kid=\"43\">\n        <div class=\"hero-img-wrap absolute inset-0 will-change-transform\" data-kid=\"44\">\n          <img src=\"https://images.unsplash.com/photo-1627518788331-b3b7fdaa382f?auto=format&w=1000&q=80&fit=crop\" alt=\"Signature Pro on Unsplash\" decoding=\"async\" loading=\"lazy\" class=\"h-[112%] w-full object-cover\" data-kid=\"45\">\n        </div>\n        <div class=\"absolute inset-0 bg-gradient-to-t from-[var(--charcoal)]/30 via-transparent to-transparent\" data-kid=\"46\"></div>\n        \n        <div class=\"absolute bottom-0 inset-x-0 bg-[var(--rose-dark)]/92 backdrop-blur-sm px-8 py-4 flex items-center justify-between\" data-kid=\"47\">\n          <span class=\"font-serif italic text-white text-[15px]\" data-kid=\"48\">« La confianza se firma en cada detalle »</span>\n          <span class=\"text-[11px] tracking-[0.3em] uppercase text-[var(--rose-light)]\" data-kid=\"49\">01 / 04</span>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"bg-[var(--beige-main)]\" data-kid=\"50\">\n    <div class=\"mx-auto max-w-[1440px] px-8 sm:px-14 lg:px-24 py-20\" data-kid=\"51\">\n      <div class=\"flex items-end justify-between mb-12\" data-kid=\"52\">\n        <h2 class=\"font-serif text-[var(--charcoal)] text-2xl sm:text-3xl max-w-md leading-snug\" data-kid=\"53\">\n          Una firma construida sobre <span class=\"italic text-[var(--rose-dark)]\" data-kid=\"54\">principios sólidos.</span>\n        </h2>\n        <span class=\"hidden sm:block text-[11px] uppercase tracking-[0.3em] text-[var(--beige-dark)]\" data-kid=\"55\">Nuestra propuesta</span>\n      </div>\n\n      <div class=\"grid sm:grid-cols-2 lg:grid-cols-4 gap-x-10 gap-y-12\" data-kid=\"56\">\n        \n        <div class=\"value-item\" data-kid=\"57\">\n          <div class=\"h-px w-full bg-[var(--copper)]/50 mb-4\" data-kid=\"58\"></div>\n          <div class=\"flex items-baseline gap-3 mb-5\" data-kid=\"59\">\n            <span class=\"font-serif text-[var(--copper)] text-3xl leading-none\" data-kid=\"60\">01</span>\n            <svg class=\"w-6 h-6 text-[var(--copper)] shrink-0\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.2\" data-kid=\"61\"><!-- stripped due to large size --></svg>\n          </div>\n          <h3 class=\"font-serif text-[var(--charcoal)] text-xl mb-2\" data-kid=\"63\">Más de 20 años de trayectoria</h3>\n          <p class=\"text-[14px] leading-relaxed text-[var(--gray-text)]\" data-kid=\"64\">Dos décadas defendiendo casos complejos y marcando jurisprudencia en tribunales.</p>\n        </div>\n        <div class=\"value-item\" data-kid=\"65\">\n          <div class=\"h-px w-full bg-[var(--copper)]/50 mb-4\" data-kid=\"66\"></div>\n          <div class=\"flex items-baseline gap-3 mb-5\" data-kid=\"67\">\n            <span class=\"font-serif text-[var(--copper)] text-3xl leading-none\" data-kid=\"68\">02</span>\n            <svg class=\"w-6 h-6 text-[var(--copper)] shrink-0\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.2\" data-kid=\"69\"><!-- stripped due to large size --></svg>\n          </div>\n          <h3 class=\"font-serif text-[var(--charcoal)] text-xl mb-2\" data-kid=\"73\">Atención personalizada</h3>\n          <p class=\"text-[14px] leading-relaxed text-[var(--gray-text)]\" data-kid=\"74\">Cada cliente cuenta con un abogado dedicado que conoce su caso a fondo.</p>\n        </div>\n        <div class=\"value-item\" data-kid=\"75\">\n          <div class=\"h-px w-full bg-[var(--copper)]/50 mb-4\" data-kid=\"76\"></div>\n          <div class=\"flex items-baseline gap-3 mb-5\" data-kid=\"77\">\n            <span class=\"font-serif text-[var(--copper)] text-3xl leading-none\" data-kid=\"78\">03</span>\n            <svg class=\"w-6 h-6 text-[var(--copper)] shrink-0\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.2\" data-kid=\"79\"><!-- stripped due to large size --></svg>\n          </div>\n          <h3 class=\"font-serif text-[var(--charcoal)] text-xl mb-2\" data-kid=\"82\">Cobertura nacional</h3>\n          <p class=\"text-[14px] leading-relaxed text-[var(--gray-text)]\" data-kid=\"83\">Representación legal en todo Chile, de Arica a Punta Arenas.</p>\n        </div>\n        <div class=\"value-item\" data-kid=\"84\">\n          <div class=\"h-px w-full bg-[var(--copper)]/50 mb-4\" data-kid=\"85\"></div>\n          <div class=\"flex items-baseline gap-3 mb-5\" data-kid=\"86\">\n            <span class=\"font-serif text-[var(--copper)] text-3xl leading-none\" data-kid=\"87\">04</span>\n            <svg class=\"w-6 h-6 text-[var(--copper)] shrink-0\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.2\" data-kid=\"88\"><!-- stripped due to large size --></svg>\n          </div>\n          <h3 class=\"font-serif text-[var(--charcoal)] text-xl mb-2\" data-kid=\"90\">Estrategia a medida</h3>\n          <p class=\"text-[14px] leading-relaxed text-[var(--gray-text)]\" data-kid=\"91\">Diseñamos una ruta jurídica única, ajustada a los objetivos de cada cliente.</p>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section id=\"servicios\" class=\"bg-[var(--beige-light)]\" data-kid=\"92\">\n    <div class=\"mx-auto max-w-[1440px] px-8 sm:px-14 lg:px-24 py-24\" data-kid=\"93\">\n      <div class=\"grid lg:grid-cols-[0.9fr_1.1fr] gap-12 lg:gap-20\" data-kid=\"94\">\n        \n        <div class=\"lg:sticky lg:top-28 self-start\" data-kid=\"95\">\n          <div class=\"flex items-center gap-4 mb-6\" data-kid=\"96\">\n            <span class=\"h-px w-10 bg-[var(--copper)]\" data-kid=\"97\"></span>\n            <span class=\"text-[11px] uppercase tracking-[0.3em] text-[var(--copper)] font-medium\" data-kid=\"98\">Áreas de Práctica</span>\n          </div>\n          <h2 class=\"font-serif text-[var(--charcoal)] text-4xl lg:text-5xl leading-[1.08] mb-6\" data-kid=\"99\">\n            Nueve especialidades, <span class=\"italic text-[var(--rose-dark)]\" data-kid=\"100\">un mismo compromiso.</span>\n          </h2>\n          <p class=\"text-[15px] leading-relaxed text-[var(--gray-text)] max-w-md mb-8\" data-kid=\"101\">\n            Cubrimos las principales ramas del derecho con equipos especializados. Explore el área que necesita y descubra cómo podemos acompañarle.\n          </p>\n          <div class=\"flex items-center gap-5 mb-8\" data-kid=\"102\">\n            <span class=\"font-serif italic text-[var(--copper)] text-5xl leading-none\" data-kid=\"103\">09</span>\n            <span class=\"text-[12px] uppercase tracking-[0.25em] text-[var(--beige-dark)] leading-snug max-w-[9rem]\" data-kid=\"104\">Áreas de especialización jurídica</span>\n          </div>\n          <a href=\"services.html\" class=\"inline-flex items-center gap-3 text-[14px] font-medium text-[var(--rose-dark)] link-underline\" data-kid=\"105\">\n            Ver todos los servicios\n            <svg class=\"w-5 h-2.5\" viewBox=\"0 0 34 8\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.2\" data-kid=\"106\"><!-- stripped due to large size --></svg>\n          </a>\n        </div>\n\n        \n        <div class=\"grid sm:grid-cols-2 gap-x-12\" data-kid=\"109\">\n          <ul class=\"divide-y divide-[var(--beige-dark)]/30\" data-kid=\"110\">\n            <li data-kid=\"111\"><a href=\"services.html\" class=\"area-row group flex items-center justify-between py-5\" data-kid=\"112\">\n              <div class=\"flex items-baseline gap-4\" data-kid=\"113\">\n                <span class=\"font-serif text-[var(--copper)] text-sm w-6\" data-kid=\"114\">01</span>\n                <span class=\"area-title font-serif text-xl text-[var(--charcoal)]\" data-kid=\"115\">Penal</span>\n              </div>\n              <i class=\"area-arrow fa-solid fa-arrow-right-long text-[var(--rose-dark)] text-sm opacity-0 -translate-x-2 transition-all\" data-kid=\"116\"></i>\n            </a></li>\n            <li data-kid=\"117\"><a href=\"services.html\" class=\"area-row group flex items-center justify-between py-5\" data-kid=\"118\">\n              <div class=\"flex items-baseline gap-4\" data-kid=\"119\">\n                <span class=\"font-serif text-[var(--copper)] text-sm w-6\" data-kid=\"120\">02</span>\n                <span class=\"area-title font-serif text-xl text-[var(--charcoal)]\" data-kid=\"121\">Civil</span>\n              </div>\n              <i class=\"area-arrow fa-solid fa-arrow-right-long text-[var(--rose-dark)] text-sm opacity-0 -translate-x-2 transition-all\" data-kid=\"122\"></i>\n            </a></li>\n            <li data-kid=\"123\"><a href=\"services.html\" class=\"area-row group flex items-center justify-between py-5\" data-kid=\"124\">\n              <div class=\"flex items-baseline gap-4\" data-kid=\"125\">\n                <span class=\"font-serif text-[var(--copper)] text-sm w-6\" data-kid=\"126\">03</span>\n                <span class=\"area-title font-serif text-xl text-[var(--charcoal)]\" data-kid=\"127\">Familia</span>\n              </div>\n              <i class=\"area-arrow fa-solid fa-arrow-right-long text-[var(--rose-dark)] text-sm opacity-0 -translate-x-2 transition-all\" data-kid=\"128\"></i>\n            </a></li>\n            <li data-kid=\"129\"><a href=\"services.html\" class=\"area-row group flex items-center justify-between py-5\" data-kid=\"130\">\n              <div class=\"flex items-baseline gap-4\" data-kid=\"131\">\n                <span class=\"font-serif text-[var(--copper)] text-sm w-6\" data-kid=\"132\">04</span>\n                <span class=\"area-title font-serif text-xl text-[var(--charcoal)]\" data-kid=\"133\">Educacional</span>\n              </div>\n              <i class=\"area-arrow fa-solid fa-arrow-right-long text-[var(--rose-dark)] text-sm opacity-0 -translate-x-2 transition-all\" data-kid=\"134\"></i>\n            </a></li>\n            <li data-kid=\"135\"><a href=\"services.html\" class=\"area-row group flex items-center justify-between py-5\" data-kid=\"136\">\n              <div class=\"flex items-baseline gap-4\" data-kid=\"137\">\n                <span class=\"font-serif text-[var(--copper)] text-sm w-6\" data-kid=\"138\">05</span>\n                <span class=\"area-title font-serif text-xl text-[var(--charcoal)]\" data-kid=\"139\">Laboral</span>\n              </div>\n              <i class=\"area-arrow fa-solid fa-arrow-right-long text-[var(--rose-dark)] text-sm opacity-0 -translate-x-2 transition-all\" data-kid=\"140\"></i>\n            </a></li>\n          </ul>\n          <ul class=\"divide-y divide-[var(--beige-dark)]/30\" data-kid=\"141\">\n            <li data-kid=\"142\"><a href=\"services.html\" class=\"area-row group flex items-center justify-between py-5\" data-kid=\"143\">\n              <div class=\"flex items-baseline gap-4\" data-kid=\"144\">\n                <span class=\"font-serif text-[var(--copper)] text-sm w-6\" data-kid=\"145\">06</span>\n                <span class=\"area-title font-serif text-xl text-[var(--charcoal)] leading-tight\" data-kid=\"146\">Decreto ley 2.695</span>\n              </div>\n              <i class=\"area-arrow fa-solid fa-arrow-right-long text-[var(--rose-dark)] text-sm opacity-0 -translate-x-2 transition-all\" data-kid=\"147\"></i>\n            </a></li>\n            <li data-kid=\"148\"><a href=\"services.html\" class=\"area-row group flex items-center justify-between py-5\" data-kid=\"149\">\n              <div class=\"flex items-baseline gap-4\" data-kid=\"150\">\n                <span class=\"font-serif text-[var(--copper)] text-sm w-6\" data-kid=\"151\">07</span>\n                <span class=\"area-title font-serif text-xl text-[var(--charcoal)]\" data-kid=\"152\">Inmobiliaria</span>\n              </div>\n              <i class=\"area-arrow fa-solid fa-arrow-right-long text-[var(--rose-dark)] text-sm opacity-0 -translate-x-2 transition-all\" data-kid=\"153\"></i>\n            </a></li>\n            <li data-kid=\"154\"><a href=\"services.html\" class=\"area-row group flex items-center justify-between py-5\" data-kid=\"155\">\n              <div class=\"flex items-baseline gap-4\" data-kid=\"156\">\n                <span class=\"font-serif text-[var(--copper)] text-sm w-6\" data-kid=\"157\">08</span>\n                <span class=\"area-title font-serif text-xl text-[var(--charcoal)]\" data-kid=\"158\">Aeronáutico</span>\n              </div>\n              <i class=\"area-arrow fa-solid fa-arrow-right-long text-[var(--rose-dark)] text-sm opacity-0 -translate-x-2 transition-all\" data-kid=\"159\"></i>\n            </a></li>\n            <li data-kid=\"160\"><a href=\"services.html\" class=\"area-row group flex items-center justify-between py-5\" data-kid=\"161\">\n              <div class=\"flex items-baseline gap-4\" data-kid=\"162\">\n                <span class=\"font-serif text-[var(--copper)] text-sm w-6\" data-kid=\"163\">09</span>\n                <span class=\"area-title font-serif text-xl text-[var(--charcoal)]\" data-kid=\"164\">Administrativo</span>\n              </div>\n              <i class=\"area-arrow fa-solid fa-arrow-right-long text-[var(--rose-dark)] text-sm opacity-0 -translate-x-2 transition-all\" data-kid=\"165\"></i>\n            </a></li>\n            <li class=\"py-5\" data-kid=\"166\">\n              <div class=\"flex items-baseline gap-4 text-[var(--beige-dark)]\" data-kid=\"167\">\n                <span class=\"font-serif text-sm w-6\" data-kid=\"168\">+</span>\n                <span class=\"text-[13px] italic font-serif\" data-kid=\"169\">Asesoría integral y continua</span>\n              </div>\n            </li>\n          </ul>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section id=\"contacto\" class=\"bg-[var(--rose-dark)] relative overflow-hidden\" data-kid=\"170\">\n    <div class=\"mx-auto max-w-[1440px] px-8 sm:px-14 lg:px-24 py-24 relative\" data-kid=\"171\">\n      <div class=\"grid lg:grid-cols-[1fr_auto] items-center gap-12\" data-kid=\"172\">\n        <div class=\"max-w-2xl\" data-kid=\"173\">\n          <span class=\"text-[11px] uppercase tracking-[0.32em] text-[var(--rose-light)] font-medium\" data-kid=\"174\">Su primer paso</span>\n          <h2 class=\"cta-head font-serif text-white text-4xl sm:text-5xl lg:text-6xl leading-[1.05] mt-5\" data-kid=\"175\">\n            Agende su <span class=\"italic\" data-kid=\"176\">consulta inicial.</span>\n          </h2>\n          <p class=\"mt-6 text-[15.5px] leading-relaxed text-white/80 max-w-lg\" data-kid=\"177\">\n            Cuéntenos su caso. Le orientaremos sobre las mejores alternativas legales sin compromiso, con la claridad y confianza que merece.\n          </p>\n        </div>\n        <div class=\"flex flex-col gap-4 shrink-0\" data-kid=\"178\">\n          <a href=\"contact.html\" class=\"inline-flex items-center justify-center gap-2.5 rounded-full bg-[var(--beige-light)] px-6 py-3 text-[14px] font-semibold text-[var(--rose-dark)] hover:bg-white transition-colors\" data-kid=\"179\">\n            Agendar consulta\n            <svg class=\"w-5 h-2.5\" viewBox=\"0 0 34 8\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.2\" data-kid=\"180\"><!-- stripped due to large size --></svg>\n          </a>\n          <a href=\"https://wa.me/56987654321\" class=\"inline-flex items-center justify-center gap-2.5 rounded-full border border-white/40 px-6 py-3 text-[14px] font-medium text-white hover:bg-white/10 transition-colors\" data-kid=\"183\">\n            <i class=\"fa-brands fa-whatsapp text-base\" data-kid=\"184\"></i>\n            WhatsApp\n          </a>\n        </div>\n      </div>\n    </div>\n    <div class=\"pointer-events-none absolute -right-20 -bottom-24 h-72 w-72 rounded-full border border-white/15\" data-kid=\"185\"></div>\n    <div class=\"pointer-events-none absolute right-24 -top-16 h-40 w-40 rounded-full border border-white/10\" data-kid=\"186\"></div>\n  </section>\n\n  \n  <footer class=\"bg-[var(--rose-dark)] border-t border-white/15\" data-kid=\"187\">\n    <div class=\"mx-auto max-w-[1440px] px-8 sm:px-14 lg:px-24 py-8 flex flex-col md:flex-row items-center justify-between gap-6\" data-kid=\"188\">\n      <a href=\"index.html\" class=\"flex items-center gap-3\" data-kid=\"189\">\n        <span class=\"grid place-items-center h-8 w-8 rounded-full border border-[var(--rose-light)]/70 text-[var(--rose-light)] font-serif italic text-sm\" data-kid=\"190\">M</span>\n        <span class=\"font-serif text-white text-[15px]\" data-kid=\"191\">Morgado &amp; Asociados</span>\n      </a>\n      <ul class=\"flex flex-wrap items-center justify-center gap-6 text-[13.5px] text-white/75\" data-kid=\"192\">\n        <li data-kid=\"193\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"194\">Política de Privacidad</a></li>\n        <li data-kid=\"195\"><span class=\"text-white/30\" data-kid=\"196\">·</span></li>\n        <li data-kid=\"197\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"198\">Aviso Legal</a></li>\n        <li data-kid=\"199\"><span class=\"text-white/30\" data-kid=\"200\">·</span></li>\n        <li data-kid=\"201\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"202\">Ética Profesional</a></li>\n      </ul>\n      <span class=\"text-[12px] italic font-serif text-[var(--rose-light)]\" data-kid=\"203\">Diseñado para la excelencia jurídica.</span>\n    </div>\n  </footer>\n</div>\n\n<link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css\" data-kid=\"204\">\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"205\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"206\"></script>\n<script data-kid=\"207\">\n  gsap.registerPlugin(ScrollTrigger);\n\n  // Hero text reveal\n  gsap.from(\".hero-eyebrow\", { y: 20, autoAlpha: 0, duration: 0.8, delay: 0.2, ease: \"power2.out\" });\n  gsap.from(\".hero-line\", { y: 40, autoAlpha: 0, duration: 0.9, delay: 0.35, stagger: 0.12, ease: \"power3.out\" });\n  gsap.from(\".hero-sub\", { y: 20, autoAlpha: 0, duration: 0.8, delay: 0.9, ease: \"power2.out\" });\n  gsap.from(\".hero-cta\", { y: 20, autoAlpha: 0, duration: 0.8, delay: 1.05, ease: \"power2.out\" });\n\n  // Hero image parallax\n  gsap.to(\".hero-img-wrap\", {\n    yPercent: -8, ease: \"none\",\n    scrollTrigger: { trigger: \"#inicio\", start: \"top top\", end: \"bottom top\", scrub: true }\n  });\n\n  // Value items reveal\n  gsap.set(\".value-item\", { autoAlpha: 0, y: 32 });\n  ScrollTrigger.batch(\".value-item\", {\n    start: \"top 88%\",\n    onEnter: (els) => gsap.to(els, { autoAlpha: 1, y: 0, duration: 0.7, stagger: 0.12, ease: \"power2.out\", overwrite: true })\n  });\n\n  // Area rows\n  gsap.from(\".area-row\", {\n    autoAlpha: 0, x: -20, duration: 0.6, stagger: 0.06, ease: \"power2.out\",\n    scrollTrigger: { trigger: \"#servicios\", start: \"top 70%\" }\n  });\n\n  // CTA head\n  gsap.from(\".cta-head\", {\n    autoAlpha: 0, y: 30, duration: 0.9, ease: \"power3.out\",\n    scrollTrigger: { trigger: \".cta-head\", start: \"top 85%\" }\n  });\n</script>",
