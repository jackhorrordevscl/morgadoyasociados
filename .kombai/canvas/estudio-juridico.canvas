      "themeId": null,
      "rect": {
        "x": 0,
        "y": 0,
        "w": 1440,
        "h": 800
      },
      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500;1,600&family=Inter:wght@300;400;500;600&display=swap');\n\n  #estudio-about {\n    font-family: 'Inter', sans-serif;\n    background-color: var(--beige-light, #F5EDE4);\n    color: var(--charcoal, #3A3235);\n    --rose-dark:#8C4B5C; --rose-main:#B37280; --rose-light:#D9A5AE;\n    --beige-dark:#A68A6D; --beige-main:#E8D9C8; --beige-light:#F5EDE4;\n    --white:#FFFFFF; --charcoal:#3A3235; --gray-text:#6E6265; --copper:#B5713D;\n    overflow-x: clip;\n  }\n  #estudio-about .font-serif { font-family: 'Playfair Display', serif; }\n  #estudio-about .line-mask { overflow: hidden; display: block; padding-bottom: 0.12em; }\n  #estudio-about .team-card { will-change: transform, opacity; }\n  #estudio-about a.navlink { position: relative; }\n  #estudio-about a.navlink::after {\n    content:''; position:absolute; left:0; bottom:-4px; height:1px; width:0;\n    background: var(--copper); transition: width .35s ease;\n  }\n  #estudio-about a.navlink:hover::after { width:100%; }\n</style>\n\n<div id=\"estudio-about\" class=\"min-h-screen antialiased\" data-kid=\"1\">\n\n  \n  <header class=\"fixed top-0 inset-x-0 z-50 px-6 lg:px-10 pt-5\" data-kid=\"2\">\n    <nav class=\"max-w-[1360px] mx-auto flex items-center justify-between rounded-full border border-white/40 bg-white/55 backdrop-blur-md px-6 lg:px-8 py-3 shadow-[0_10px_40px_-18px_rgba(58,50,53,0.35)]\" data-kid=\"3\">\n      <a href=\"index.html\" class=\"flex items-center gap-3 shrink-0\" data-kid=\"4\">\n        <span class=\"grid place-items-center h-9 w-9 rounded-full border border-[var(--copper)]/60 text-[var(--copper)] font-serif italic text-lg leading-none\" data-kid=\"5\">M</span>\n        <span class=\"leading-tight\" data-kid=\"6\">\n          <span class=\"block font-serif text-[17px] text-[var(--charcoal)] tracking-tight\" data-kid=\"205\">Morgado &amp; Asociados</span>\n          <span class=\"block text-[9px] uppercase tracking-[0.35em] text-[var(--copper)]\" data-kid=\"206\">Asesoría Legal · Chile</span>\n        </span>\n      </a>\n      <ul class=\"hidden lg:flex items-center gap-9 text-[13px] tracking-wide text-[var(--charcoal)]/85\" data-kid=\"7\">\n        <li data-kid=\"8\"><a href=\"index.html\" class=\"navlink\" data-kid=\"9\">Inicio</a></li>\n        <li data-kid=\"10\"><a href=\"about.html\" class=\"navlink text-[var(--rose-dark)] font-semibold\" data-kid=\"11\">Sobre Nosotros</a></li>\n        <li data-kid=\"12\"><a href=\"services.html\" class=\"navlink\" data-kid=\"13\">Servicios</a></li>\n        <li data-kid=\"14\"><a href=\"contact.html\" class=\"navlink\" data-kid=\"15\">Contacto</a></li>\n      </ul>\n      <a href=\"contact.html\" class=\"inline-flex items-center gap-2 bg-[var(--rose-dark)] text-[var(--white)] text-[13px] tracking-wide font-medium px-6 py-3 rounded-full hover:bg-[var(--rose-main)] transition-colors\" data-kid=\"16\">\n        Consulta Inicial\n        <i class=\"fa-solid fa-arrow-right text-[11px]\" data-kid=\"17\"></i>\n      </a>\n    </nav>\n  </header>\n  <div class=\"h-20\" aria-hidden=\"true\" data-kid=\"207\"></div>\n\n  \n  <section class=\"max-w-[1200px] mx-auto px-8 pt-24 pb-20\" data-kid=\"18\">\n    <div class=\"grid grid-cols-12 gap-8 items-end\" data-kid=\"19\">\n      <div class=\"col-span-12 lg:col-span-8\" data-kid=\"20\">\n        <p class=\"text-[var(--copper)] text-[12px] tracking-[0.35em] uppercase font-semibold mb-7\" data-kid=\"21\">Nuestra Firma</p>\n        <h1 class=\"reveal-title font-serif text-[var(--rose-dark)] leading-[1.1] text-[clamp(2.8rem,5.5vw,5rem)]\" data-kid=\"22\">\n          <span class=\"line-mask\" data-kid=\"23\"><span class=\"line-inner block\" data-kid=\"24\">Más de <span class=\"italic\" data-kid=\"25\">20 años</span></span></span>\n          <span class=\"line-mask\" data-kid=\"26\"><span class=\"line-inner block italic\" data-kid=\"27\">marcando</span></span>\n          <span class=\"line-mask\" data-kid=\"28\"><span class=\"line-inner block\" data-kid=\"29\">jurisprudencia.</span></span>\n        </h1>\n      </div>\n      <div class=\"col-span-12 lg:col-span-4\" data-kid=\"30\">\n        <div class=\"border-t border-[var(--copper)]/50 pt-6\" data-kid=\"31\">\n          <p class=\"text-[var(--gray-text)] text-[15px] leading-relaxed\" data-kid=\"32\">\n            Somos un estudio jurídico chileno construido sobre la confianza, la excelencia técnica y un compromiso genuino con cada persona que representamos. Traducimos la complejidad legal en tranquilidad.\n          </p>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"max-w-[1200px] mx-auto px-8 pb-28\" data-kid=\"33\">\n    <div class=\"flex flex-col lg:flex-row gap-16 items-start\" data-kid=\"34\">\n      \n      <div class=\"w-full lg:w-[40%] lg:sticky lg:top-28 shrink-0\" data-kid=\"35\">\n        <p class=\"text-[var(--copper)] text-[12px] tracking-[0.3em] uppercase font-semibold mb-6\" data-kid=\"36\">Trayectoria</p>\n        <h2 class=\"font-serif text-[2.4rem] leading-[1.15] text-[var(--charcoal)] mb-8\" data-kid=\"37\">\n          Cada caso es una historia que merece ser <span class=\"italic text-[var(--rose-dark)]\" data-kid=\"38\">defendida con rigor</span>.\n        </h2>\n        <p class=\"text-[var(--gray-text)] text-[15px] leading-relaxed mb-10 max-w-md\" data-kid=\"39\">\n          Desde nuestra fundación hemos acompañado a familias, empresas y personas naturales en los momentos que más importan, con una estrategia hecha a la medida.\n        </p>\n        <div class=\"grid grid-cols-3 gap-8 border-t border-[var(--beige-dark)]/40 pt-8\" data-kid=\"40\">\n          <div data-kid=\"41\">\n            <p class=\"font-serif text-[var(--copper)] text-[2.6rem] leading-none\" data-kid=\"42\">20<span class=\"text-2xl\" data-kid=\"43\">+</span></p>\n            <p class=\"text-[var(--gray-text)] text-[12px] tracking-wide mt-2 leading-tight\" data-kid=\"44\">Años de<br data-kid=\"45\">experiencia</p>\n          </div>\n          <div data-kid=\"46\">\n            <p class=\"font-serif text-[var(--copper)] text-[2.6rem] leading-none\" data-kid=\"47\">1.2<span class=\"text-2xl\" data-kid=\"48\">k</span></p>\n            <p class=\"text-[var(--gray-text)] text-[12px] tracking-wide mt-2 leading-tight\" data-kid=\"49\">Casos<br data-kid=\"50\">resueltos</p>\n          </div>\n          <div data-kid=\"51\">\n            <p class=\"font-serif text-[var(--copper)] text-[2.6rem] leading-none\" data-kid=\"52\">09</p>\n            <p class=\"text-[var(--gray-text)] text-[12px] tracking-wide mt-2 leading-tight\" data-kid=\"53\">Áreas de<br data-kid=\"54\">práctica</p>\n          </div>\n        </div>\n      </div>\n\n      \n      <div class=\"flex-1 w-full\" data-kid=\"55\">\n        <div class=\"space-y-14\" data-kid=\"56\">\n          <article class=\"diff-block border-t border-[var(--copper)]/40 pt-8\" data-kid=\"57\">\n            <div class=\"flex items-start gap-6\" data-kid=\"58\">\n              <span class=\"font-serif text-[var(--rose-light)] text-2xl leading-none mt-1\" data-kid=\"59\">01</span>\n              <div data-kid=\"60\">\n                <h3 class=\"font-serif text-[1.6rem] text-[var(--rose-dark)] mb-3\" data-kid=\"61\">Enfoque personalizado</h3>\n                <p class=\"text-[var(--gray-text)] text-[15px] leading-relaxed max-w-xl\" data-kid=\"62\">\n                  No creemos en las soluciones genéricas. Estudiamos cada expediente en profundidad y diseñamos una estrategia jurídica única para las circunstancias, objetivos y prioridades de cada cliente.\n                </p>\n              </div>\n            </div>\n          </article>\n          <article class=\"diff-block border-t border-[var(--copper)]/40 pt-8\" data-kid=\"63\">\n            <div class=\"flex items-start gap-6\" data-kid=\"64\">\n              <span class=\"font-serif text-[var(--rose-light)] text-2xl leading-none mt-1\" data-kid=\"65\">02</span>\n              <div data-kid=\"66\">\n                <h3 class=\"font-serif text-[1.6rem] text-[var(--rose-dark)] mb-3\" data-kid=\"67\">Ética y transparencia</h3>\n                <p class=\"text-[var(--gray-text)] text-[15px] leading-relaxed max-w-xl\" data-kid=\"68\">\n                  Comunicamos con claridad el estado real de cada proceso, sus riesgos y sus costos. La confianza se construye sobre la honestidad, y esa es la base de toda relación con nuestros representados.\n                </p>\n              </div>\n            </div>\n          </article>\n          <article class=\"diff-block border-t border-[var(--copper)]/40 pt-8\" data-kid=\"69\">\n            <div class=\"flex items-start gap-6\" data-kid=\"70\">\n              <span class=\"font-serif text-[var(--rose-light)] text-2xl leading-none mt-1\" data-kid=\"71\">03</span>\n              <div data-kid=\"72\">\n                <h3 class=\"font-serif text-[1.6rem] text-[var(--rose-dark)] mb-3\" data-kid=\"73\">Resultados comprobados</h3>\n                <p class=\"text-[var(--gray-text)] text-[15px] leading-relaxed max-w-xl\" data-kid=\"74\">\n                  Más de dos décadas de sentencias favorables y acuerdos exitosos respaldan nuestro trabajo. Medimos nuestro éxito por la tranquilidad que devolvemos a quienes confían en nosotros.\n                </p>\n              </div>\n            </div>\n          </article>\n          <article class=\"diff-block border-t border-[var(--copper)]/40 pt-8\" data-kid=\"75\">\n            <div class=\"flex items-start gap-6\" data-kid=\"76\">\n              <span class=\"font-serif text-[var(--rose-light)] text-2xl leading-none mt-1\" data-kid=\"77\">04</span>\n              <div data-kid=\"78\">\n                <h3 class=\"font-serif text-[1.6rem] text-[var(--rose-dark)] mb-3\" data-kid=\"79\">Cobertura nacional</h3>\n                <p class=\"text-[var(--gray-text)] text-[15px] leading-relaxed max-w-xl\" data-kid=\"80\">\n                  Con presencia y red de contactos a lo largo de todo Chile, representamos a nuestros clientes ante tribunales de cualquier región, garantizando una defensa cercana sin importar la distancia.\n                </p>\n              </div>\n            </div>\n          </article>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"bg-[var(--white)] py-28 border-y border-[var(--beige-dark)]/25\" data-kid=\"81\">\n    <div class=\"max-w-[1200px] mx-auto px-8\" data-kid=\"82\">\n      <div class=\"flex flex-col md:flex-row md:items-end justify-between mb-16 gap-6\" data-kid=\"83\">\n        <div data-kid=\"84\">\n          <p class=\"text-[var(--copper)] text-[12px] tracking-[0.35em] uppercase font-semibold mb-5\" data-kid=\"85\">El Equipo</p>\n          <h2 class=\"font-serif text-[2.8rem] leading-tight text-[var(--charcoal)]\" data-kid=\"86\">Quienes <span class=\"italic text-[var(--rose-dark)]\" data-kid=\"87\">defienden</span> por usted</h2>\n        </div>\n        <p class=\"text-[var(--gray-text)] text-[15px] leading-relaxed max-w-sm md:text-right\" data-kid=\"88\">\n          Un equipo multidisciplinario de abogados y abogadas comprometidos con la excelencia jurídica.\n        </p>\n      </div>\n\n      <div class=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-x-8 gap-y-14\" data-kid=\"89\">\n        \n        <div class=\"team-card text-center\" data-kid=\"90\">\n          <div class=\"relative inline-block mb-6\" data-kid=\"91\">\n            <div class=\"w-44 h-44 rounded-full p-[3px] ring-1 ring-[var(--rose-dark)] ring-offset-4 ring-offset-[var(--white)]\" data-kid=\"92\">\n              <img src=\"https://images.unsplash.com/photo-1518556336318-c8de4355ccab?auto=format&w=600&q=80&fit=crop\" alt=\"M.T ElGassier on Unsplash\" decoding=\"async\" loading=\"lazy\" class=\"w-full h-full object-cover rounded-full grayscale\" data-kid=\"93\">\n            </div>\n          </div>\n          <h3 class=\"font-serif text-[1.35rem] text-[var(--charcoal)]\" data-kid=\"94\">Mtro. Ignacio Fuentes</h3>\n          <p class=\"text-[var(--copper)] text-[12px] tracking-[0.15em] uppercase font-semibold mt-1 mb-3\" data-kid=\"95\">Socio Fundador</p>\n          <p class=\"text-[var(--gray-text)] text-[13.5px] leading-relaxed px-2\" data-kid=\"96\">Lidera la firma con más de dos décadas defendiendo causas de alta complejidad.</p>\n        </div>\n        \n        <div class=\"team-card text-center\" data-kid=\"97\">\n          <div class=\"relative inline-block mb-6\" data-kid=\"98\">\n            <div class=\"w-44 h-44 rounded-full p-[3px] ring-1 ring-[var(--rose-dark)] ring-offset-4 ring-offset-[var(--white)]\" data-kid=\"99\">\n              <img src=\"https://images.unsplash.com/photo-1585240975735-4826abe53080?auto=format&w=600&q=80&fit=crop\" alt=\"PodMatch on Unsplash\" decoding=\"async\" loading=\"lazy\" class=\"w-full h-full object-cover rounded-full grayscale\" data-kid=\"100\">\n            </div>\n          </div>\n          <h3 class=\"font-serif text-[1.35rem] text-[var(--charcoal)]\" data-kid=\"101\">Abg. Carolina Rojas</h3>\n          <p class=\"text-[var(--copper)] text-[12px] tracking-[0.15em] uppercase font-semibold mt-1 mb-3\" data-kid=\"102\">Socia Área Civil</p>\n          <p class=\"text-[var(--gray-text)] text-[13.5px] leading-relaxed px-2\" data-kid=\"103\">Especialista en litigios civiles y contratos, con enfoque estratégico y meticuloso.</p>\n        </div>\n        \n        <div class=\"team-card text-center\" data-kid=\"104\">\n          <div class=\"relative inline-block mb-6\" data-kid=\"105\">\n            <div class=\"w-44 h-44 rounded-full p-[3px] ring-1 ring-[var(--rose-dark)] ring-offset-4 ring-offset-[var(--white)]\" data-kid=\"106\">\n              <img src=\"https://images.unsplash.com/photo-1645990543673-53d612fee13e?auto=format&w=600&q=80&fit=crop\" alt=\"Max Nüstedt on Unsplash\" decoding=\"async\" loading=\"lazy\" class=\"w-full h-full object-cover rounded-full grayscale\" data-kid=\"107\">\n            </div>\n          </div>\n          <h3 class=\"font-serif text-[1.35rem] text-[var(--charcoal)]\" data-kid=\"108\">Abg. Valentina Soto</h3>\n          <p class=\"text-[var(--copper)] text-[12px] tracking-[0.15em] uppercase font-semibold mt-1 mb-3\" data-kid=\"109\">Asociada Área Familia</p>\n          <p class=\"text-[var(--gray-text)] text-[13.5px] leading-relaxed px-2\" data-kid=\"110\">Acompaña a las familias con empatía en procesos de cuidado personal y alimentos.</p>\n        </div>\n        \n        <div class=\"team-card text-center\" data-kid=\"111\">\n          <div class=\"relative inline-block mb-6\" data-kid=\"112\">\n            <div class=\"w-44 h-44 rounded-full p-[3px] ring-1 ring-[var(--rose-dark)] ring-offset-4 ring-offset-[var(--white)]\" data-kid=\"113\">\n              <img src=\"https://images.unsplash.com/photo-1612283061725-f22721e5a3cd?auto=format&w=600&q=80&fit=crop\" alt=\"Vincent NICOLAS on Unsplash\" decoding=\"async\" loading=\"lazy\" class=\"w-full h-full object-cover rounded-full grayscale\" data-kid=\"114\">\n            </div>\n          </div>\n          <h3 class=\"font-serif text-[1.35rem] text-[var(--charcoal)]\" data-kid=\"115\">Mtro. Rodrigo Vera</h3>\n          <p class=\"text-[var(--copper)] text-[12px] tracking-[0.15em] uppercase font-semibold mt-1 mb-3\" data-kid=\"116\">Consultor Área Penal</p>\n          <p class=\"text-[var(--gray-text)] text-[13.5px] leading-relaxed px-2\" data-kid=\"117\">Defensor penal con amplia trayectoria en juicios orales y recursos ante la Corte.</p>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"bg-[var(--beige-main)] py-28\" data-kid=\"118\">\n    <div class=\"max-w-[900px] mx-auto px-8 text-center\" data-kid=\"119\">\n      <span class=\"font-serif text-[var(--rose-light)] text-[6rem] leading-[0.5] block mb-2\" data-kid=\"120\">&ldquo;</span>\n      <blockquote class=\"font-serif italic text-[var(--charcoal)] text-[clamp(1.6rem,3vw,2.6rem)] leading-[1.35]\" data-kid=\"121\">\n        Nuestra misión no es solo ganar casos, sino restituir la tranquilidad de quienes nos confían sus asuntos más importantes. Ahí reside la verdadera justicia.\n      </blockquote>\n      <div class=\"mt-10 flex items-center justify-center gap-4\" data-kid=\"122\">\n        <span class=\"w-10 h-px bg-[var(--copper)]\" data-kid=\"123\"></span>\n        <p class=\"text-[var(--gray-text)] text-[13px] tracking-[0.15em] uppercase\" data-kid=\"124\">Mtro. Ignacio Fuentes · Socio Fundador</p>\n        <span class=\"w-10 h-px bg-[var(--copper)]\" data-kid=\"125\"></span>\n      </div>\n    </div>\n  </section>\n\n  \n  <footer class=\"bg-[var(--rose-dark)] text-[var(--white)]\" data-kid=\"126\">\n    <div class=\"max-w-[1200px] mx-auto px-8 py-16\" data-kid=\"127\">\n      <div class=\"flex flex-col md:flex-row items-center justify-between gap-8 pb-10 border-b border-white/15\" data-kid=\"128\">\n        <p class=\"font-serif text-2xl\" data-kid=\"129\">Nos ponemos a su <span class=\"italic\" data-kid=\"130\">disposición</span>.</p>\n        <a href=\"contact.html\" class=\"inline-flex items-center gap-2 bg-[var(--white)] text-[var(--rose-dark)] text-[13px] tracking-wide font-semibold px-7 py-3 rounded-full hover:bg-[var(--beige-light)] transition-colors\" data-kid=\"131\">\n          Agende su consulta <i class=\"fa-solid fa-arrow-right text-[11px]\" data-kid=\"132\"></i>\n        </a>\n      </div>\n      <div class=\"flex flex-col md:flex-row items-center justify-between gap-6 pt-8\" data-kid=\"133\">\n        <a href=\"index.html\" class=\"flex items-center gap-3\" data-kid=\"134\">\n          <span class=\"grid place-items-center h-8 w-8 rounded-full border border-[var(--rose-light)]/70 text-[var(--rose-light)] font-serif italic text-sm\" data-kid=\"1341\">M</span>\n          <span class=\"font-serif text-white text-[15px]\" data-kid=\"1342\">Morgado &amp; Asociados</span>\n        </a>\n        <ul class=\"flex flex-wrap items-center justify-center gap-6 text-[13.5px] text-white/75\" data-kid=\"136\">\n          <li data-kid=\"137\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"138\">Política de Privacidad</a></li>\n          <li data-kid=\"139\"><span class=\"text-white/30\" data-kid=\"140\">·</span></li>\n          <li data-kid=\"1391\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"1401\">Aviso Legal</a></li>\n          <li data-kid=\"1392\"><span class=\"text-white/30\" data-kid=\"1402\">·</span></li>\n          <li data-kid=\"141\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"142\">Ética Profesional</a></li>\n        </ul>\n        <p class=\"text-[12px] text-white/60 italic\" data-kid=\"143\">Diseñado para la excelencia jurídica.</p>\n      </div>\n    </div>\n  </footer>\n\n</div>\n\n<link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css\" data-kid=\"144\">\n\n<script type=\"module\" data-kid=\"145\">\n  import { animate, stagger } from \"https://esm.sh/animejs@4\";\n  import { inView } from \"https://cdn.jsdelivr.net/npm/motion@12/+esm\";\n\n  // Line-mask reveal on header title\n  const inners = document.querySelectorAll('#estudio-about .line-inner');\n  animate(inners, {\n    y: ['110%', '0%'],\n    delay: stagger(110),\n    duration: 850,\n    ease: 'out(4)'\n  });\n\n  // Staggered team reveal\n  inView('#estudio-about .team-card', (el) => {\n    animate(el, { opacity: [0,1], y: [40,0], duration: 700, ease: 'out(3)' });\n  }, { margin: '0px 0px -15% 0px' });\n\n  // Diff blocks subtle reveal\n  inView('#estudio-about .diff-block', (el) => {\n    animate(el, { opacity: [0,1], y: [24,0], duration: 650, ease: 'out(3)' });\n  }, { margin: '0px 0px -10% 0px' });\n</script>",
