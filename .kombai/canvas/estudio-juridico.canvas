      "html": "<style data-kid=\"0\">\n@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,500;0,600;0,700;1,500;1,600&family=Inter:wght@400;500;600&display=swap');\n.font-serif{font-family:'Playfair Display',serif}\n.font-body{font-family:'Inter',sans-serif}\n:root{\n  --rose-dark:#8C4B5C;--rose-main:#B37280;--rose-light:#D9A5AE;\n  --beige-dark:#A68A6D;--beige-main:#E8D9C8;--beige-light:#F5EDE4;\n  --white:#FFFFFF;--charcoal:#3A3235;--gray-text:#6E6265;--copper:#B5713D;\n}\n.svc{box-shadow:0 2px 4px rgba(0,0,0,.05)}\n.svc:hover{box-shadow:0 16px 44px rgba(140,75,92,.18);transform:translateY(-6px)}\n.nav-link{position:relative}\n.nav-link::after{content:\"\";position:absolute;left:0;bottom:-4px;height:1.5px;width:0;background:var(--copper);transition:width .3s ease}\n.nav-link:hover::after{width:100%}\n.nav-active::after{width:100%}\n.btn-fill{transition:transform .3s ease,box-shadow .3s ease}\n.btn-fill:hover{transform:translateY(-2px);box-shadow:0 12px 30px rgba(140,75,92,.25)}\n</style>\n\n<div class=\"font-body\" style=\"background:var(--beige-light);color:var(--charcoal)\" data-kid=\"1\">\n\n  \n  <header class=\"fixed top-0 inset-x-0 z-50 px-6 lg:px-10 pt-5\" data-kid=\"2\">\n    <div class=\"max-w-[1360px] mx-auto flex items-center justify-between rounded-full border border-white/40 bg-white/55 backdrop-blur-md px-6 lg:px-8 py-3 shadow-[0_10px_40px_-18px_rgba(58,50,53,0.35)]\" data-kid=\"3\">\n      <a href=\"index.html\" class=\"flex items-center gap-3 shrink-0\" data-kid=\"4\">\n        <span class=\"grid place-items-center h-9 w-9 rounded-full border border-[var(--copper)]/60 text-[var(--copper)] font-serif italic text-lg leading-none\" data-kid=\"5\">M</span>\n        <span class=\"leading-tight\" data-kid=\"6\">\n          <span class=\"block font-serif text-[17px] tracking-tight\" style=\"color:var(--charcoal)\" data-kid=\"205\">Morgado &amp; Asociados</span>\n          <span class=\"block text-[9px] uppercase tracking-[0.35em]\" style=\"color:var(--copper)\" data-kid=\"206\">Asesoría Legal · Chile</span>\n        </span>\n      </a>\n      <nav class=\"hidden md:flex items-center gap-9 text-[13px] tracking-wide\" style=\"color:var(--charcoal)\" data-kid=\"10\">\n        <a href=\"index.html\" class=\"nav-link\" data-kid=\"11\">Inicio</a>\n        <a href=\"about.html\" class=\"nav-link\" data-kid=\"12\">Sobre Nosotros</a>\n        <a href=\"services.html\" class=\"nav-link nav-active\" style=\"color:var(--rose-dark)\" data-kid=\"13\">Servicios</a>\n        <a href=\"contact.html\" class=\"nav-link\" data-kid=\"14\">Contacto</a>\n      </nav>\n      <a href=\"contact.html\" class=\"btn-fill hidden md:inline-block px-6 py-2.5 rounded-full text-sm font-medium text-white\" style=\"background:var(--rose-dark)\" data-kid=\"15\">Consulta Inicial</a>\n    </div>\n  </header>\n  <div class=\"h-20\" aria-hidden=\"true\" data-kid=\"207\"></div>\n\n  \n  <section class=\"px-10 pt-24 pb-20\" style=\"background:var(--beige-light)\" data-kid=\"16\">\n    <div class=\"max-w-5xl mx-auto text-center\" data-kid=\"17\">\n      <p class=\"text-xs font-semibold tracking-[0.35em] uppercase mb-6\" style=\"color:var(--copper)\" data-kid=\"18\">Áreas de Práctica</p>\n      <h1 class=\"font-serif italic font-semibold leading-[1.1] text-5xl md:text-6xl mb-8\" style=\"color:var(--rose-dark)\" data-kid=\"19\">Asesoría integral en cada<br data-kid=\"20\">disciplina del derecho</h1>\n      <p class=\"max-w-2xl mx-auto text-lg leading-relaxed\" style=\"color:var(--gray-text)\" data-kid=\"21\">Cada materia jurídica exige un enfoque propio. Nuestro equipo combina rigor técnico y trato cercano para proteger sus intereses en todas las ramas del derecho, con estrategias diseñadas a la medida de su caso.</p>\n      <div class=\"mt-10 flex items-center justify-center gap-4\" data-kid=\"22\">\n        <span class=\"h-px w-16\" style=\"background:var(--beige-dark)\" data-kid=\"23\"></span>\n        <span class=\"text-lg\" style=\"color:var(--copper)\" data-kid=\"24\">§</span>\n        <span class=\"h-px w-16\" style=\"background:var(--beige-dark)\" data-kid=\"25\"></span>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"px-10 py-24\" style=\"background:var(--beige-main)\" data-kid=\"26\">\n    <div class=\"max-w-6xl mx-auto\" data-kid=\"27\">\n      <div class=\"flex items-end justify-between mb-12 flex-wrap gap-4\" data-kid=\"28\">\n        <h2 class=\"font-serif text-3xl md:text-4xl\" style=\"color:var(--charcoal)\" data-kid=\"29\">Nueve áreas de especialización</h2>\n        <p class=\"text-sm max-w-xs\" style=\"color:var(--gray-text)\" data-kid=\"30\">Explore las disciplinas en las que ofrecemos representación y consejo experto.</p>\n      </div>\n\n      <div class=\"columns-1 md:columns-2 lg:columns-3 gap-6\" data-kid=\"31\">\n\n        \n        <div class=\"svc break-inside-avoid mb-6 bg-white rounded-2xl p-8 border\" style=\"border-color:rgba(166,138,109,.5)\" data-kid=\"32\">\n          <div style=\"color:var(--copper)\" class=\"mb-6\" data-kid=\"33\">\n            <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"36\" height=\"36\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" data-kid=\"34\"><!-- stripped due to large size --></svg>\n          </div>\n          <h3 class=\"font-serif text-2xl mb-2\" style=\"color:var(--rose-dark)\" data-kid=\"36\">Penal</h3>\n          <p class=\"text-sm leading-relaxed\" style=\"color:var(--gray-text)\" data-kid=\"37\">Defensa penal estratégica y representación en litigios ante los tribunales de justicia.</p>\n        </div>\n\n        \n        <div class=\"svc break-inside-avoid mb-6 rounded-2xl p-8 border\" style=\"border-color:rgba(166,138,109,.5);background:linear-gradient(160deg,#fff,var(--beige-light))\" data-kid=\"38\">\n          <div class=\"flex items-start justify-between mb-6\" data-kid=\"39\">\n            <div style=\"color:var(--copper)\" data-kid=\"40\">\n              <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"36\" height=\"36\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" data-kid=\"41\"><!-- stripped due to large size --></svg>\n            </div>\n            <span class=\"text-[11px] font-semibold tracking-widest uppercase px-3 py-1 rounded-full\" style=\"background:var(--beige-main);color:var(--copper)\" data-kid=\"43\">Especialidad</span>\n          </div>\n          <h3 class=\"font-serif text-2xl mb-2\" style=\"color:var(--rose-dark)\" data-kid=\"44\">Educacional</h3>\n          <p class=\"text-sm leading-relaxed mb-5\" style=\"color:var(--gray-text)\" data-kid=\"45\">Asesoría en normativa escolar, procedimientos y conflictos educativos, con acompañamiento a toda la comunidad.</p>\n          <div class=\"flex flex-wrap gap-2\" data-kid=\"46\">\n            <span class=\"text-xs px-3 py-1.5 rounded-full border\" style=\"border-color:var(--rose-main);color:var(--rose-dark)\" data-kid=\"47\">Apoderados</span>\n            <span class=\"text-xs px-3 py-1.5 rounded-full border\" style=\"border-color:var(--rose-main);color:var(--rose-dark)\" data-kid=\"48\">Docentes</span>\n            <span class=\"text-xs px-3 py-1.5 rounded-full border\" style=\"border-color:var(--rose-main);color:var(--rose-dark)\" data-kid=\"49\">Sostenedores</span>\n          </div>\n        </div>\n\n        \n        <div class=\"svc break-inside-avoid mb-6 bg-white rounded-2xl p-8 border\" style=\"border-color:rgba(166,138,109,.5)\" data-kid=\"50\">\n          <div style=\"color:var(--copper)\" class=\"mb-6\" data-kid=\"51\">\n            <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"36\" height=\"36\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" data-kid=\"52\"><!-- stripped due to large size --></svg>\n          </div>\n          <h3 class=\"font-serif text-2xl mb-2\" style=\"color:var(--rose-dark)\" data-kid=\"54\">Civil</h3>\n          <p class=\"text-sm leading-relaxed\" style=\"color:var(--gray-text)\" data-kid=\"55\">Contratos, responsabilidad civil y cumplimiento de obligaciones patrimoniales.</p>\n        </div>\n\n        \n        <div class=\"svc break-inside-avoid mb-6 rounded-2xl p-8 border-0\" style=\"background:var(--rose-dark);color:var(--beige-light)\" data-kid=\"56\">\n          <div style=\"color:var(--rose-light)\" class=\"mb-6\" data-kid=\"57\">\n            <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"36\" height=\"36\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" data-kid=\"58\"><!-- stripped due to large size --></svg>\n          </div>\n          <p class=\"text-[11px] font-semibold tracking-widest uppercase mb-3\" style=\"color:var(--rose-light)\" data-kid=\"60\">Área Destacada</p>\n          <h3 class=\"font-serif text-2xl mb-3 text-white\" data-kid=\"61\">Decreto Ley 2.695</h3>\n          <p class=\"text-sm leading-relaxed mb-5\" style=\"color:var(--beige-main)\" data-kid=\"62\">Regularización de la pequeña propiedad raíz y saneamiento de títulos de dominio de bienes nacionales, un procedimiento técnico que dominamos con experiencia.</p>\n          <span class=\"inline-flex items-center gap-2 text-xs font-medium\" style=\"color:var(--rose-light)\" data-kid=\"63\">Bienes Nacionales\n            <svg width=\"14\" height=\"14\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\" data-kid=\"64\"><!-- stripped due to large size --></svg>\n          </span>\n        </div>\n\n        \n        <div class=\"svc break-inside-avoid mb-6 bg-white rounded-2xl p-8 border\" style=\"border-color:rgba(166,138,109,.5)\" data-kid=\"66\">\n          <div style=\"color:var(--copper)\" class=\"mb-6\" data-kid=\"67\">\n            <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"36\" height=\"36\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" data-kid=\"68\"><!-- stripped due to large size --></svg>\n          </div>\n          <h3 class=\"font-serif text-2xl mb-2\" style=\"color:var(--rose-dark)\" data-kid=\"70\">Familia</h3>\n          <p class=\"text-sm leading-relaxed\" style=\"color:var(--gray-text)\" data-kid=\"71\">Divorcios, pensiones de alimentos y regímenes de cuidado personal.</p>\n        </div>\n\n        \n        <div class=\"svc break-inside-avoid mb-6 bg-white rounded-2xl p-8 border\" style=\"border-color:rgba(166,138,109,.5)\" data-kid=\"72\">\n          <div style=\"color:var(--copper)\" class=\"mb-6\" data-kid=\"73\">\n            <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"36\" height=\"36\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" data-kid=\"74\"><!-- stripped due to large size --></svg>\n          </div>\n          <h3 class=\"font-serif text-2xl mb-2\" style=\"color:var(--rose-dark)\" data-kid=\"77\">Laboral</h3>\n          <p class=\"text-sm leading-relaxed\" style=\"color:var(--gray-text)\" data-kid=\"78\">Despidos, negociación colectiva y defensa de derechos laborales.</p>\n        </div>\n\n        \n        <div class=\"svc break-inside-avoid mb-6 bg-white rounded-2xl p-8 border\" style=\"border-color:rgba(166,138,109,.5)\" data-kid=\"79\">\n          <div style=\"color:var(--copper)\" class=\"mb-6\" data-kid=\"80\">\n            <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"36\" height=\"36\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" data-kid=\"81\"><!-- stripped due to large size --></svg>\n          </div>\n          <h3 class=\"font-serif text-2xl mb-2\" style=\"color:var(--rose-dark)\" data-kid=\"83\">Inmobiliaria</h3>\n          <p class=\"text-sm leading-relaxed\" style=\"color:var(--gray-text)\" data-kid=\"84\">Compraventa, arriendos y litigios inmobiliarios de todo tipo.</p>\n        </div>\n\n        \n        <div class=\"svc break-inside-avoid mb-6 bg-white rounded-2xl p-8 border\" style=\"border-color:rgba(166,138,109,.5)\" data-kid=\"85\">\n          <div style=\"color:var(--copper)\" class=\"mb-6\" data-kid=\"86\">\n            <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"36\" height=\"36\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" data-kid=\"87\"><!-- stripped due to large size --></svg>\n          </div>\n          <h3 class=\"font-serif text-2xl mb-2\" style=\"color:var(--rose-dark)\" data-kid=\"89\">Aeronáutico</h3>\n          <p class=\"text-sm leading-relaxed\" style=\"color:var(--gray-text)\" data-kid=\"90\">Derecho aeronáutico y cumplimiento de la normativa de la DGAC.</p>\n        </div>\n\n        \n        <div class=\"svc break-inside-avoid mb-6 bg-white rounded-2xl p-8 border\" style=\"border-color:rgba(166,138,109,.5)\" data-kid=\"91\">\n          <div style=\"color:var(--copper)\" class=\"mb-6\" data-kid=\"92\">\n            <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"36\" height=\"36\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" data-kid=\"93\"><!-- stripped due to large size --></svg>\n          </div>\n          <h3 class=\"font-serif text-2xl mb-2\" style=\"color:var(--rose-dark)\" data-kid=\"95\">Administrativo</h3>\n          <p class=\"text-sm leading-relaxed\" style=\"color:var(--gray-text)\" data-kid=\"96\">Procedimientos y recursos ante la administración del Estado.</p>\n        </div>\n\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"px-10 py-24\" style=\"background:var(--beige-light)\" data-kid=\"97\">\n    <p class=\"text-xs font-semibold tracking-[0.3em] uppercase mb-4 text-center\" style=\"color:var(--copper)\" data-kid=\"98\">Nuestro Método</p>\n    <h2 class=\"font-serif italic text-4xl md:text-5xl text-center mb-16\" style=\"color:var(--rose-dark)\" data-kid=\"99\">Un proceso claro en cada caso</h2>\n    <div class=\"max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-x-10 gap-y-12\" data-kid=\"100\">\n      <div class=\"proc-step px-1\" data-kid=\"101\">\n        <span class=\"font-serif text-6xl leading-none\" style=\"color:var(--copper)\" data-kid=\"102\">01</span>\n        <div class=\"h-px w-full my-6\" style=\"background:var(--beige-dark)\" data-kid=\"103\"></div>\n        <h4 class=\"font-serif text-xl mb-2\" style=\"color:var(--charcoal)\" data-kid=\"104\">Consulta inicial</h4>\n        <p class=\"text-sm leading-relaxed\" style=\"color:var(--gray-text)\" data-kid=\"105\">Escuchamos su situación y evaluamos con claridad las alternativas legales disponibles.</p>\n      </div>\n      <div class=\"proc-step px-1\" data-kid=\"106\">\n        <span class=\"font-serif text-6xl leading-none\" style=\"color:var(--copper)\" data-kid=\"107\">02</span>\n        <div class=\"h-px w-full my-6\" style=\"background:var(--beige-dark)\" data-kid=\"108\"></div>\n        <h4 class=\"font-serif text-xl mb-2\" style=\"color:var(--charcoal)\" data-kid=\"109\">Análisis del caso</h4>\n        <p class=\"text-sm leading-relaxed\" style=\"color:var(--gray-text)\" data-kid=\"110\">Estudiamos los antecedentes en profundidad y determinamos la viabilidad jurídica.</p>\n      </div>\n      <div class=\"proc-step px-1\" data-kid=\"111\">\n        <span class=\"font-serif text-6xl leading-none\" style=\"color:var(--copper)\" data-kid=\"112\">03</span>\n        <div class=\"h-px w-full my-6\" style=\"background:var(--beige-dark)\" data-kid=\"113\"></div>\n        <h4 class=\"font-serif text-xl mb-2\" style=\"color:var(--charcoal)\" data-kid=\"114\">Estrategia</h4>\n        <p class=\"text-sm leading-relaxed\" style=\"color:var(--gray-text)\" data-kid=\"115\">Diseñamos un plan de acción a la medida de sus objetivos y prioridades.</p>\n      </div>\n      <div class=\"proc-step px-1\" data-kid=\"116\">\n        <span class=\"font-serif text-6xl leading-none\" style=\"color:var(--copper)\" data-kid=\"117\">04</span>\n        <div class=\"h-px w-full my-6\" style=\"background:var(--beige-dark)\" data-kid=\"118\"></div>\n        <h4 class=\"font-serif text-xl mb-2\" style=\"color:var(--charcoal)\" data-kid=\"119\">Representación</h4>\n        <p class=\"text-sm leading-relaxed\" style=\"color:var(--gray-text)\" data-kid=\"120\">Le acompañamos y defendemos con firmeza hasta la resolución definitiva.</p>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"px-10 py-24\" style=\"background:var(--rose-dark)\" data-kid=\"121\">\n    <div class=\"max-w-3xl mx-auto text-center\" data-kid=\"122\">\n      <span class=\"text-3xl\" style=\"color:var(--rose-light)\" data-kid=\"123\">§</span>\n      <h2 class=\"font-serif italic text-4xl md:text-5xl text-white mt-4 mb-5\" data-kid=\"124\">¿No encuentra su área?</h2>\n      <p class=\"text-lg mb-10\" style=\"color:var(--rose-light)\" data-kid=\"125\">Consulte con nosotros. Evaluamos cada caso de forma personalizada y le orientamos sin compromiso hacia la mejor solución jurídica.</p>\n      <div class=\"flex flex-wrap gap-4 justify-center\" data-kid=\"126\">\n        <a href=\"contact.html\" class=\"btn-fill px-8 py-3.5 rounded-full font-medium\" style=\"background:var(--beige-light);color:var(--rose-dark)\" data-kid=\"127\">Solicitar consulta</a>\n        <a href=\"https://wa.me/56987654321\" class=\"btn-fill px-8 py-3.5 rounded-full font-medium text-white border flex items-center gap-2\" style=\"border-color:var(--rose-light)\" data-kid=\"128\">\n          <svg width=\"18\" height=\"18\" fill=\"currentColor\" viewBox=\"0 0 24 24\" data-kid=\"129\"><!-- stripped due to large size --></svg>\n          WhatsApp\n        </a>\n      </div>\n    </div>\n  </section>\n\n  \n  <footer class=\"px-10 py-10\" style=\"background:var(--rose-dark)\" data-kid=\"131\">\n    <div class=\"max-w-7xl mx-auto\" data-kid=\"132\">\n      <div class=\"h-px w-full mb-8\" style=\"background:rgba(217,165,174,.3)\" data-kid=\"133\"></div>\n      <div class=\"flex flex-col md:flex-row items-center justify-between gap-6\" data-kid=\"134\">\n        <a href=\"index.html\" class=\"flex items-center gap-3 text-white\" data-kid=\"135\">\n          <span class=\"grid place-items-center h-8 w-8 rounded-full border border-[var(--rose-light)]/70 text-[var(--rose-light)] font-serif italic text-sm\" data-kid=\"136\">M</span>\n          <span class=\"font-serif text-lg\" data-kid=\"139\">Morgado &amp; Asociados</span>\n        </a>\n        <nav class=\"flex flex-wrap items-center justify-center gap-6 text-xs\" style=\"color:var(--rose-light)\" data-kid=\"140\">\n          <a href=\"#\" class=\"hover:text-white\" data-kid=\"141\">Política de Privacidad</a>\n          <a href=\"#\" class=\"hover:text-white\" data-kid=\"142\">Aviso Legal</a>\n          <a href=\"#\" class=\"hover:text-white\" data-kid=\"143\">Ética Profesional</a>\n        </nav>\n        <p class=\"text-xs italic\" style=\"color:var(--beige-main)\" data-kid=\"144\">Diseñado para la excelencia jurídica.</p>\n      </div>\n    </div>\n  </footer>\n\n</div>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"145\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"146\"></script>\n<script data-kid=\"147\">\n  gsap.registerPlugin(ScrollTrigger);\n  gsap.set(\".svc\", { autoAlpha: 0, y: 34 });\n  ScrollTrigger.batch(\".svc\", {\n    start: \"top 88%\",\n    batchMax: 6,\n    interval: 0.08,\n    onEnter: (els) => gsap.to(els, { autoAlpha: 1, y: 0, duration: 0.55, stagger: 0.07, ease: \"power2.out\", overwrite: true })\n  });\n  gsap.set(\".proc-step\", { autoAlpha: 0, y: 28 });\n  ScrollTrigger.batch(\".proc-step\", {\n    start: \"top 90%\",\n    onEnter: (els) => gsap.to(els, { autoAlpha: 1, y: 0, duration: 0.5, stagger: 0.1, ease: \"power2.out\", overwrite: true })\n  });\n</script>",
