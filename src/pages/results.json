  "shellOpenBeforeHeader": "\n<div class=\"lp-root font-sans antialiased\">\n\n  ",
  "pageContentBetweenShell": "\n\n  <section class=\"relative\">\n    <div class=\"mx-auto max-w-360 px-6 sm:px-14 lg:px-24 pt-32 sm:pt-40 pb-14 sm:pb-20\">\n      <div class=\"hero-eyebrow flex items-center gap-4 mb-6 sm:mb-8\">\n        <span class=\"mt-2 h-px w-8 sm:w-10 bg-(--copper)\"></span>\n        <span class=\"text-[11px] uppercase tracking-[0.32em] text-(--copper) font-medium\">Casos &amp; Resultados</span>\n      </div>\n      <h1 class=\"mobile-hero-title font-serif text-(--rose-dark) leading-[1.05] text-[clamp(2.4rem,6vw,4.6rem)] max-w-3xl\">\n        <span class=\"hero-line block italic font-semibold\">Resultados que</span>\n        <span class=\"hero-line block not-italic font-semibold text-(--charcoal)\">respaldan cada</span>\n        <span class=\"hero-line block italic font-semibold\">estrategia.</span>\n      </h1>\n      <p class=\"hero-sub mt-6 sm:mt-8 max-w-xl text-[15px] sm:text-[15.5px] leading-relaxed text-(--gray-text)\">\n        No medimos nuestro trabajo solo en sentencias, sino en la tranquilidad que devolvemos. Estas son las cifras y las voces de quienes confiaron su caso a nuestra firma.\n      </p>\n    </div>\n  </section>\n\n  <section class=\"bg-(--beige-main)\">\n    <div class=\"mx-auto max-w-360 px-6 sm:px-14 lg:px-24 py-14 sm:py-20\">\n      <div class=\"flex items-end justify-between mb-10 sm:mb-12\">\n        <h2 class=\"font-serif text-(--charcoal) text-2xl sm:text-3xl max-w-md leading-snug\">\n          Cifras que reflejan <span class=\"italic text-(--rose-dark)\">dos décadas de trabajo.</span>\n        </h2>\n        <span class=\"hidden sm:block text-[11px] uppercase tracking-[0.3em] text-(--beige-dark)\">Resultados medibles</span>\n      </div>\n\n      <div class=\"grid sm:grid-cols-2 lg:grid-cols-4 gap-x-10 gap-y-10 sm:gap-y-12\">\n        <div class=\"stat-item\">\n          <div class=\"h-px w-full bg-(--copper)/50 mb-4\"></div>\n          <div class=\"flex items-baseline gap-3 mb-5\">\n            <span class=\"font-serif text-(--copper) text-3xl leading-none\">95%</span>\n            <svg class=\"stat-icon w-6 h-6 text-(--copper) shrink-0 transition-colors\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.2\"><path d=\"M20 6L9 17l-5-5\"></path></svg>\n          </div>\n          <h3 class=\"font-serif text-(--charcoal) text-xl mb-2\">Casos con resultado favorable</h3>\n          <p class=\"text-sm leading-relaxed text-(--gray-text)\">Sentencias, acuerdos y resoluciones administrativas a favor de nuestros representados.</p>\n        </div>\n        <div class=\"stat-item\">\n          <div class=\"h-px w-full bg-(--copper)/50 mb-4\"></div>\n          <div class=\"flex items-baseline gap-3 mb-5\">\n            <span class=\"font-serif text-(--copper) text-3xl leading-none\">1.2k</span>\n            <svg class=\"stat-icon w-6 h-6 text-(--copper) shrink-0 transition-colors\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.2\"><path d=\"M4 19h16M7 19V9l5-5 5 5v10\"></path></svg>\n          </div>\n          <h3 class=\"font-serif text-(--charcoal) text-xl mb-2\">Casos resueltos</h3>\n          <p class=\"text-sm leading-relaxed text-(--gray-text)\">Entre litigios, asesorías y procedimientos administrativos desde nuestra fundación.</p>\n        </div>\n        <div class=\"stat-item\">\n          <div class=\"h-px w-full bg-(--copper)/50 mb-4\"></div>\n          <div class=\"flex items-baseline gap-3 mb-5\">\n            <span class=\"font-serif text-(--copper) text-3xl leading-none\">24h</span>\n            <svg class=\"stat-icon w-6 h-6 text-(--copper) shrink-0 transition-colors\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.2\"><circle cx=\"12\" cy=\"12\" r=\"9\"></circle><path d=\"M12 7v5l3 3\"></path></svg>\n          </div>\n          <h3 class=\"font-serif text-(--charcoal) text-xl mb-2\">Tiempo de primera respuesta</h3>\n          <p class=\"text-sm leading-relaxed text-(--gray-text)\">Evaluamos cada consulta con rapidez, sin sacrificar rigor en el análisis.</p>\n        </div>\n        <div class=\"stat-item\">\n          <div class=\"h-px w-full bg-(--copper)/50 mb-4\"></div>\n          <div class=\"flex items-baseline gap-3 mb-5\">\n            <span class=\"font-serif text-(--copper) text-3xl leading-none\">4.9</span>\n            <svg class=\"stat-icon w-6 h-6 text-(--copper) shrink-0 transition-colors\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.2\"><path d=\"M12 2l2.5 5.5L20 8l-4 4 1 6-5-3-5 3 1-6-4-4 5.5-.5z\"></path></svg>\n          </div>\n          <h3 class=\"font-serif text-(--charcoal) text-xl mb-2\">Satisfacción de clientes</h3>\n          <p class=\"text-sm leading-relaxed text-(--gray-text)\">Calificación promedio sobre 5, según encuestas de cierre de caso.</p>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <section class=\"bg-(--beige-light)\">\n    <div class=\"mx-auto max-w-360 px-6 sm:px-14 lg:px-24 py-16 sm:py-24\">\n      <div class=\"flex items-end justify-between mb-10 sm:mb-14 flex-wrap gap-4\">\n        <div class=\"max-w-lg\">\n          <div class=\"flex items-start gap-4 mb-6\">\n            <span class=\"mt-2 h-px w-8 sm:w-10 bg-(--copper)\"></span>\n            <span class=\"text-[11px] uppercase tracking-[0.3em] text-(--copper) font-medium\">Casos Destacados</span>\n          </div>\n          <h2 class=\"font-serif text-(--charcoal) text-3xl sm:text-4xl leading-[1.1]\">\n            Resultados concretos, <span class=\"italic text-(--rose-dark)\">por área de práctica.</span>\n          </h2>\n        </div>\n        <p class=\"text-sm leading-relaxed text-(--gray-text) max-w-sm\">Una muestra de los desafíos que hemos resuelto para personas, familias y empresas en todo Chile.</p>\n      </div>\n\n      <div class=\"grid sm:grid-cols-2 lg:grid-cols-3 gap-6\">\n        <div class=\"case-card bg-white rounded-lg p-8 border border-(--beige-dark)/40\">\n          <span class=\"text-[11px] font-semibold tracking-widest uppercase text-(--copper)\">Penal</span>\n          <h3 class=\"font-serif text-xl text-(--rose-dark) mt-3 mb-3\">Absolución total en juicio oral por delito económico</h3>\n          <p class=\"text-sm leading-relaxed text-(--gray-text) mb-5\">Defensa estratégica que desestimó la totalidad de los cargos imputados, tras un análisis exhaustivo de la prueba.</p>\n          <span class=\"inline-flex items-center gap-2 text-[13px] font-semibold text-(--rose-dark)\">Absolución total</span>\n        </div>\n        <div class=\"case-card bg-white rounded-lg p-8 border border-(--beige-dark)/40\">\n          <span class=\"text-[11px] font-semibold tracking-widest uppercase text-(--copper)\">Civil</span>\n          <h3 class=\"font-serif text-xl text-(--rose-dark) mt-3 mb-3\">Recuperación de $180M por incumplimiento contractual</h3>\n          <p class=\"text-sm leading-relaxed text-(--gray-text) mb-5\">Sentencia favorable en primera instancia que restituyó íntegramente el patrimonio comprometido de nuestro cliente.</p>\n          <span class=\"inline-flex items-center gap-2 text-[13px] font-semibold text-(--rose-dark)\">Sentencia favorable</span>\n        </div>\n        <div class=\"case-card rounded-lg p-8 border-0 bg-(--rose-dark) text-(--beige-light)\">\n          <span class=\"text-[11px] font-semibold tracking-widest uppercase text-(--rose-light)\">Laboral</span>\n          <h3 class=\"font-serif text-xl text-white mt-3 mb-3\">Indemnización 40% superior en despido injustificado</h3>\n          <p class=\"text-sm leading-relaxed text-(--beige-main) mb-5\">Negociamos una compensación muy por encima de la oferta inicial de la empresa, sin necesidad de litigio prolongado.</p>\n          <span class=\"inline-flex items-center gap-2 text-[13px] font-semibold text-(--rose-light)\">+40% de indemnización</span>\n        </div>\n        <div class=\"case-card bg-white rounded-lg p-8 border border-(--beige-dark)/40\">\n          <span class=\"text-[11px] font-semibold tracking-widest uppercase text-(--copper)\">Familia</span>\n          <h3 class=\"font-serif text-xl text-(--rose-dark) mt-3 mb-3\">Compensación económica acordada sin litigio</h3>\n          <p class=\"text-sm leading-relaxed text-(--gray-text) mb-5\">Mediación exitosa que evitó un proceso judicial prolongado, preservando la relación familiar tras el divorcio.</p>\n          <span class=\"inline-flex items-center gap-2 text-[13px] font-semibold text-(--rose-dark)\">Acuerdo vía mediación</span>\n        </div>\n        <div class=\"case-card bg-white rounded-lg p-8 border border-(--beige-dark)/40\">\n          <span class=\"text-[11px] font-semibold tracking-widest uppercase text-(--copper)\">Decreto Ley 2.695</span>\n          <h3 class=\"font-serif text-xl text-(--rose-dark) mt-3 mb-3\">Saneamiento de títulos para 12 familias</h3>\n          <p class=\"text-sm leading-relaxed text-(--gray-text) mb-5\">Regularizamos la propiedad raíz de una comunidad completa, resolviendo disputas de dominio de larga data.</p>\n          <span class=\"inline-flex items-center gap-2 text-[13px] font-semibold text-(--rose-dark)\">12 familias regularizadas</span>\n        </div>\n        <div class=\"case-card bg-white rounded-lg p-8 border border-(--beige-dark)/40\">\n          <span class=\"text-[11px] font-semibold tracking-widest uppercase text-(--copper)\">Administrativo</span>\n          <h3 class=\"font-serif text-xl text-(--rose-dark) mt-3 mb-3\">Reversión de sanción municipal</h3>\n          <p class=\"text-sm leading-relaxed text-(--gray-text) mb-5\">Recurso de reposición que dejó sin efecto una multa administrativa, evitando el pago y el cierre del negocio del cliente.</p>\n          <span class=\"inline-flex items-center gap-2 text-[13px] font-semibold text-(--rose-dark)\">Sanción revertida</span>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <section class=\"bg-(--beige-main)\">\n    <div class=\"mx-auto max-w-360 px-6 sm:px-14 lg:px-24 py-16 sm:py-24\">\n      <div class=\"flex items-end justify-between mb-10 sm:mb-14 flex-wrap gap-4\">\n        <div class=\"flex items-start gap-4\">\n          <span class=\"mt-2 h-px w-8 sm:w-10 bg-(--copper)\"></span>\n          <h2 class=\"font-serif text-(--charcoal) text-3xl sm:text-4xl leading-[1.1] max-w-md\">\n            Lo que dicen <span class=\"italic text-(--rose-dark)\">quienes confiaron en nosotros.</span>\n          </h2>\n        </div>\n        <span class=\"hidden sm:block text-[11px] uppercase tracking-[0.3em] text-(--beige-dark)\">Testimonios</span>\n      </div>\n\n      <div class=\"grid sm:grid-cols-2 lg:grid-cols-4 gap-6\">\n        <div class=\"quote-card bg-white rounded-lg p-7 border border-transparent\">\n          <div class=\"flex gap-0.5 mb-5 text-(--copper) text-xs\">\n            <i class=\"fa-solid fa-star\"></i><i class=\"fa-solid fa-star\"></i><i class=\"fa-solid fa-star\"></i><i class=\"fa-solid fa-star\"></i><i class=\"fa-solid fa-star\"></i>\n          </div>\n          <p class=\"font-serif italic text-[15px] leading-relaxed text-(--charcoal) mb-6\">&ldquo;Sentí que mi caso era la prioridad de principio a fin. Explicaron cada paso con claridad y logramos un acuerdo mejor del que esperaba.&rdquo;</p>\n          <div class=\"flex items-center gap-3\">\n            <span class=\"grid place-items-center h-9 w-9 rounded-full border border-(--copper)/60 text-(--copper) font-serif italic text-sm leading-none\">R</span>\n            <div>\n              <p class=\"text-[13px] font-medium text-(--charcoal)\">R. Mardones</p>\n              <p class=\"text-[11px] uppercase tracking-widest text-(--beige-dark)\">Cliente · Área Civil</p>\n            </div>\n          </div>\n        </div>\n        <div class=\"quote-card bg-white rounded-lg p-7 border border-transparent\">\n          <div class=\"flex gap-0.5 mb-5 text-(--copper) text-xs\">\n            <i class=\"fa-solid fa-star\"></i><i class=\"fa-solid fa-star\"></i><i class=\"fa-solid fa-star\"></i><i class=\"fa-solid fa-star\"></i><i class=\"fa-solid fa-star\"></i>\n          </div>\n          <p class=\"font-serif italic text-[15px] leading-relaxed text-(--charcoal) mb-6\">&ldquo;Enfrentar un proceso penal es aterrador, pero la defensa que recibí fue rigurosa, cercana y efectiva. Estoy profundamente agradecido.&rdquo;</p>\n          <div class=\"flex items-center gap-3\">\n            <span class=\"grid place-items-center h-9 w-9 rounded-full border border-(--copper)/60 text-(--copper) font-serif italic text-sm leading-none\">J</span>\n            <div>\n              <p class=\"text-[13px] font-medium text-(--charcoal)\">J. Peralta</p>\n              <p class=\"text-[11px] uppercase tracking-widest text-(--beige-dark)\">Cliente · Área Penal</p>\n            </div>\n          </div>\n        </div>\n        <div class=\"quote-card bg-white rounded-lg p-7 border border-transparent\">\n          <div class=\"flex gap-0.5 mb-5 text-(--copper) text-xs\">\n            <i class=\"fa-solid fa-star\"></i><i class=\"fa-solid fa-star\"></i><i class=\"fa-solid fa-star\"></i><i class=\"fa-solid fa-star\"></i><i class=\"fa-solid fa-star\"></i>\n          </div>\n          <p class=\"font-serif italic text-[15px] leading-relaxed text-(--charcoal) mb-6\">&ldquo;Resolvieron la tenencia y pensión de mis hijos con empatía y firmeza. Hoy tenemos la tranquilidad familiar que tanto necesitábamos.&rdquo;</p>\n          <div class=\"flex items-center gap-3\">\n            <span class=\"grid place-items-center h-9 w-9 rounded-full border border-(--copper)/60 text-(--copper) font-serif italic text-sm leading-none\">C</span>\n            <div>\n              <p class=\"text-[13px] font-medium text-(--charcoal)\">C. Salazar</p>\n              <p class=\"text-[11px] uppercase tracking-widest text-(--beige-dark)\">Clienta · Área Familia</p>\n            </div>\n          </div>\n        </div>\n        <div class=\"quote-card bg-white rounded-lg p-7 border border-transparent\">\n          <div class=\"flex gap-0.5 mb-5 text-(--copper) text-xs\">\n            <i class=\"fa-solid fa-star\"></i><i class=\"fa-solid fa-star\"></i><i class=\"fa-solid fa-star\"></i><i class=\"fa-solid fa-star\"></i><i class=\"fa-solid fa-star\"></i>\n          </div>\n          <p class=\"font-serif italic text-[15px] leading-relaxed text-(--charcoal) mb-6\">&ldquo;Nos asesoraron en la regularización de un terreno que llevaba años pendiente. Profesionalismo impecable de principio a fin.&rdquo;</p>\n          <div class=\"flex items-center gap-3\">\n            <span class=\"grid place-items-center h-9 w-9 rounded-full border border-(--copper)/60 text-(--copper) font-serif italic text-sm leading-none\">V</span>\n            <div>\n              <p class=\"text-[13px] font-medium text-(--charcoal)\">Familia Vera</p>\n              <p class=\"text-[11px] uppercase tracking-widest text-(--beige-dark)\">Clientes · Decreto Ley 2.695</p>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <section class=\"bg-(--rose-dark) relative overflow-hidden\">\n    <div class=\"mx-auto max-w-360 px-6 sm:px-14 lg:px-24 py-16 sm:py-24 relative\">\n      <div class=\"grid lg:grid-cols-[1fr_auto] items-center gap-12\">\n        <div class=\"max-w-2xl\">\n          <span class=\"text-[11px] uppercase tracking-[0.32em] text-(--rose-light) font-medium\">Su próximo capítulo</span>\n          <h2 class=\"cta-head font-serif text-white text-3xl sm:text-5xl lg:text-6xl leading-[1.05] mt-5\">\n            ¿Quiere ser nuestro <span class=\"italic\">próximo resultado?</span>\n          </h2>\n          <p class=\"mt-6 text-[15.5px] leading-relaxed text-white/80 max-w-lg\">\n            Cuéntenos su caso y evaluaremos, sin compromiso, la mejor estrategia para alcanzar el resultado que necesita.\n          </p>\n        </div>\n        <div class=\"flex flex-col gap-4 shrink-0\">\n          <a href=\"contact.html\" class