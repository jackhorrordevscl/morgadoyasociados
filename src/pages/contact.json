span class=\"grid place-items-center w-12 h-12 rounded-full shrink-0\" style=\"background:#25D366\">\n            <i class=\"fa-brands fa-whatsapp text-2xl text-white\"></i>\n          </span>\n          <div class=\"flex-1\">\n            <p class=\"text-[11px] uppercase tracking-widest\" style=\"color:#8ce6a8\">Escríbanos por WhatsApp</p>\n            <p class=\"text-lg font-semibold\" style=\"color:var(--white)\">+56 9 8765 4321</p>\n          </div>\n          <span class=\"text-lg\" style=\"color:#8ce6a8\"><i class=\"fa-solid fa-arrow-right\"></i></span>\n        </a>\n\n        \n        <div class=\"flex items-center gap-3 mt-10\">\n          <span class=\"text-xs tracking-widest uppercase mr-2\" style=\"color:var(--beige-dark)\">Más redes próximamente</span>\n          <a href=\"https://www.instagram.com/asesoriaslegales.morgado_cia\" target=\"_blank\" rel=\"noopener noreferrer\" aria-label=\"Instagram de Asesoría Legal Morgado, Cía. & Asociados\" title=\"Instagram\" class=\"grid place-items-center w-10 h-10 rounded-full text-base transition-colors hover:text-white\" style=\"background:rgba(245,237,228,.08);color:var(--beige-light);border:1px solid rgba(181,113,61,.4)\"><svg class=\"\" width=\"1em\" height=\"1em\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\" focusable=\"false\"><rect x=\"4\" y=\"4\" width=\"16\" height=\"16\" rx=\"4\"/><circle cx=\"12\" cy=\"12\" r=\"3.5\"/><circle cx=\"17\" cy=\"7\" r=\".75\" fill=\"currentColor\" stroke=\"none\"/></svg></a>\n          <span role=\"img\" aria-label=\"LinkedIn: perfil aún no disponible\" title=\"LinkedIn próximamente\" class=\"grid place-items-center w-10 h-10 rounded-full text-base\" style=\"background:rgba(245,237,228,.08);color:var(--beige-light);border:1px solid rgba(181,113,61,.4)\"><svg class=\"\" width=\"1em\" height=\"1em\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=