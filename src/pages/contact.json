m-help\" aria-busy=\"false\">\n          <input type=\"text\" name=\"website\" tabindex=\"-1\" autocomplete=\"off\" style=\"position:absolute;left:-9999px\" aria-hidden=\"true\">\n          <div>\n            <label for=\"f-name\" class=\"block text-sm font-medium mb-1.5\" style=\"color:var(--charcoal)\">Nombre completo</label>\n            <input id=\"f-name\" name=\"nombre\" type=\"text\" required placeholder=\"Su nombre\" autocomplete=\"name\" class=\"field w-full rounded-lg px-4 py-3 outline-none text-base\" style=\"border:1px solid var(--beige-dark)\">\n          </div>\n          <div class=\"grid grid-cols-2 gap-4\">\n            <div>\n              <label for=\"f-email\" class=\"block text-sm font-medium mb-1.5\" style=\"color:var(--charcoal)\">Correo electrónico</label>\n              <input id=\"f-email\" name=\"email\" type=\"email\" required placeholder=\"correo@ejemplo.cl\" autocomplete=\"email\" inputmode=\"email\" class=\"field w-full rounded-lg px-4 py-3 outline-none text-base\" style=\"border:1px solid var(--beige-dark)\">\n            </div>\n            <div>\n              <label for=\"f-phone\" class=\"block text-sm font-medium mb-1.5\" style=\"color:var(--charcoal)\">Teléfono</label>\n              <input id=\"f-phone\" name=\"telefono\" type=\"tel\" placeholder=\"+56 9 ...\" autocomplete=\"tel\" inputmode=\"tel\" class=\"field w-full rounded-lg px-4 py-3 outline-none text-base\" style=\"border:1px solid var(--beige-dark)\">\n            </div>\n          </div>\n          <div>\n            <label for=\"f-area\" class=\"block text-sm font-medium mb-1.5\" style=\"color:var(--charcoal)\">Área de interés</label>\n            <select id=\"f-area\" name=\"area\" class=\"field w-full rounded-lg px-4 py-3 outline-none text-base pr-12\" style=\"border:1px solid var(--beige-dark);color:var(--charcoal)\">\n              <option value>Seleccione un área</option>\n              <option>Penal</option>\n              <option>Civil</option>\n              <option>Familia</option>\n              <option>Educacional</option>\n              <option>Laboral</option>\n              <option>Decreto Ley 2.695</option>\n              <option>Inmobiliaria</option>\n              <option>Aeronáutico</option>\n              <option>Administrativo</option>\n            </select>\n          </div>\n          <div>\n            <label for=\"f-msg\" class=\"block text-sm font-medium mb-1.5\" style=\"color:var(--charcoal)\">Mensaje</label>\n            <textarea id=\"f-msg\" name=\"mensaje\" rows=\"4\" required placeholder=\"Describa brevemente su situación...\" class=\"field w-full rounded-lg px-4 py-3 outline-none text-base resize-none\" style=\"border:1px solid var(--beige-dark)\"></textarea>\n          </div>\n          <div class=\"flex items-start gap-3 pt-1\">\n            <input id=\"privacy-consent\" name=\"privacy_consent\" type=\"checkbox\" value=\"accepted\" required class=\"mt-0.75 h-4 w-4 shrink-0 accent-(--rose-dark)\" style=\"border:1px solid var(--beige-dark)\">\n            <label for=\"privacy-consent\" class=\"text-sm leading-relaxed\" style=\"color:var(--gray-text)\">He leído la <a href=\"legal.html#privacidad\" class=\"font-medium text-(--rose-dark) link-underline\">Política de Privacidad</a> y autorizo el tratamiento de mis datos para responder a esta consulta.</label>\n          </div>\n          <div class=\"flex items-center gap-4 pt-1\" id=\"btn-wrap\">\n            <button id=\"submit-btn\" type=\"submit\" aria-label=\"Enviar consulta\" class=\"relative grid place-items-center h-13 w-full rounded-lg text-white font-semibold text-[15px] overflow-hidden\" style=\"background:var(--rose-dark)\">\n              <span id=\"btn-label\" class=\"pointer-events-none\">Enviar consulta</span>\n              <svg id=\"check-svg\" class=\"absolute\" width=\"28\" height=\"28\" viewBox=\"0 0 28 28\" fill=\"none\" style=\"opacity:0\">\n                <path id=\"check-path\" d=\"M7 14.5L12 19L21 9\" stroke=\"white\" stroke-width=\"2.4\" stroke-linecap=\"round\" stroke-linejoin=\"round\"></path>\n              </svg>\n            </button>\n          </div>\n          <p id=\"success-msg\" role=\"status\" aria-live=\"polite\" aria-atomic=\"true\" aria-hidden=\"true\" tabindex=\"-1\" class=\"text-sm font-medium\" style=\"color:var(--copper);opacity:0\">Gracias. Recibimos su consulta y le responderemos dentro de 24 horas hábiles.</p>\n          <p id=\"error-msg\" role=\"alert\" aria-live=\"assertive\" aria-atomic=\"true\" aria-hidden=\"true\" tabindex=\"-1\" class=\"text-sm font-medium\" style=\"color:#b3312c;opacity:0\">No se pudo enviar su consulta. Intente nuevamente.</p>\n        </form>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"mx-auto max-w-360 px-6 sm:px-14 lg:px-24 py-16 sm:py-20\">\n    <div class=\"rounded-lg overflow-hidden shadow-[0_20px_60px_rgba(58,50,53,.15)]\" style=\"border:1px solid var(--beige-dark)\">\n      <div class=\"flex items-center gap-3 px-6 py-4\" style=\"background:var(--rose-dark)\">\n        <span class=\"text-white text-lg\"><i class=\"fa-solid fa-location-dot\"></i></span>\n        <p class=\"text-white font-serif text-lg tracking-wide\">Nuestra oficina en el centro de Santiago</p>\n      </div>\n      <div class=\"relative\" style=\"background:var(--beige-main)\">\n        <div class=\"absolute inset-0 pointer-events-none z-10\" style=\"box-shadow:inset 0 0 90px rgba(140,75,92,.14)\"></div>\n        <iframe title=\"Mapa de la oficina en Santiago Centro\" class=\"w-full block\" style=\"height:420px;border:0\" src=\"https://www.openstreetmap.org/export/embed.html?bbox=-70.65%2C-33.45%2C-70.63%2C-33.43&layer=mapnik&marker=-33.4393,-70.6443\" loading=\"lazy\"></iframe>\n      </div>\n    </div>\n  </section>\n\n  \n  \n",
