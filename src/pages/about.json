{
  "shellOpenBeforeHeader": "\n\n<div id=\"estudio-about\" class=\"lp-root font-sans min-h-screen antialiased\">\n\n  \n  ",
  "pageContentBetweenShell": "\n  <div class=\"h-20\" aria-hidden=\"true\"></div>\n\n  \n  <section class=\"mx-auto max-w-360 px-6 sm:px-14 lg:px-24 pt-20 sm:pt-24 pb-14 sm:pb-20\">\n    <div class=\"grid grid-cols-12 gap-8 items-end\">\n      <div class=\"col-span-12 lg:col-span-8\">\n        <p class=\"text-(--copper) text-xs tracking-[0.22em] sm:tracking-[0.35em] uppercase font-semibold mb-5 sm:mb-7\">Nuestra Firma</p>\n        <h1 class=\"reveal-title mobile-hero-title font-serif text-(--rose-dark) leading-[1.1] text-[clamp(2.25rem,11vw,5rem)]\">\n          <span class=\"line-mask\"><span class=\"line-inner block\">Más de <span class=\"italic\">20 años</span></span></span>\n          <span class=\"line-mask\"><span class=\"line-inner block italic\">marcando</span></span>\n          <span class=\"line-mask\"><span class=\"line-inner block\">jurisprudencia.</span></span>\n        </h1>\n      </div>\n      <div class=\"col-span-12 lg:col-span-4\">\n        <div class=\"border-t border-(--copper)/50 pt-6 mt-6 lg:mt-0\">\n          <p class=\"text-(--gray-text) text-[15px] leading-relaxed\">\n            Somos un estudio jurídico chileno construido sobre la confianza, la excelencia técnica y un compromiso genuino con cada persona que representamos. Traducimos la complejidad legal en tranquilidad.\n          </p>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"mx-auto max-w-360 px-6 sm:px-14 lg:px-24 pb-16 sm:pb-20 lg:pb-28\">\n    <div class=\"flex flex-col lg:flex-row gap-10 sm:gap-16 items-start\">\n      \n      <div class=\"w-full lg:w-[40%] lg:sticky lg:top-28 shrink-0\">\n        <p class=\"text-(--copper) text-xs tracking-[0.22em] sm:tracking-[0.3em] uppercase font-semibold mb-6\">Trayectoria</p>\n        <h2 class=\"font-serif text-[clamp(1.75rem,6vw,2.4rem)] leading-[1.15] text-(--charcoal) mb-8\">\n          Cada caso es una historia que merece ser <span class=\"italic text-(--rose-dark)\">defendida con rigor</span>.\n        </h2>\n        <p class=\"text-(--gray-text) text-[15px] leading-relaxed mb-10 max-w-md\">\n          Desde nuestra fundación hemos acompañado a familias, empresas y personas naturales en los momentos que más importan, con una estrategia hecha a la medida.\n        </p>\n        <div class=\"grid grid-cols-3 gap-4 sm:gap-6 lg:gap-8 border-t border-(--beige-dark)/40 pt-6 sm:pt-8\">\n          <div>\n            <p class=\"font-serif text-(--copper) text-[clamp(1.75rem,8vw,2.6rem)] leading-none\">20<span class=\"text-xl sm:text-2xl\">+</span></p>\n            <p class=\"text-(--gray-text) text-[11px] sm:text-xs tracking-wide mt-2 leading-tight\">Años de<br>experiencia</p>\n          </div>\n          <div>\n            <p class=\"font-serif text-(--copper) text-[clamp(1.75rem,8vw,2.6rem)] leading-none\">1.2<span class=\"text-xl sm:text-2xl\">k</span></p>\n            <p class=\"text-(--gray-text) text-[11px] sm:text-xs tracking-wide mt-2 leading-tight\">Casos<br>resueltos</p>\n          </div>\n          <div>\n            <p class=\"font-serif text-(--copper) text-[clamp(1.75rem,8vw,2.6rem)] leading-none\">09</p>\n            <p class=\"text-(--gray-text) text-[11px] sm:text-xs tracking-wide mt-2 leading-tight\">Áreas de<br>práctica</p>\n          </div>\n        </div>\n      </div>\n\n      \n      <div class=\"flex-1 w-full\">\n        <div class=\"space-y-10 sm:space-y-14\">\n          <article class=\"diff-block border-t border-(--copper)/40 pt-8\">\n            <div class=\"flex items-start gap-4 sm:gap-6\">\n              <span class=\"font-serif text-(--rose-light) text-xl sm:text-2xl leading-none mt-1\">01</span>\n              <div>\n                <h3 class=\"font-serif text-[clamp(1.25rem,4.5vw,1.6rem)] text-(--rose-dark) mb-3\">Enfoque personalizado</h3>\n                <p class=\"text-(--gray-text) text-[15px] leading-relaxed max-w-xl\">\n                  No creemos en las soluciones genéricas. Estudiamos cada expediente en profundidad y diseñamos una estrategia jurídica única para las circunstancias, objetivos y prioridades de cada cliente.\n                </p>\n              </div>\n            </div>\n          </article>\n          <article class=\"diff-block border-t border-(--copper)/40 pt-8\">\n            <div class=\"flex items-start gap-4 sm:gap-6\">\n              <span class=\"font-serif text-(--rose-light) text-xl sm:text-2xl leading-none mt-1\">02</span>\n              <div>\n                <h3 class=\"font-serif text-[clamp(1.25rem,4.5vw,1.6rem)] text-(--rose-dark) mb-3\">Ética y transparencia</h3>\n                <p class=\"text-(--gray-text) text-[15px] leading-relaxed max-w-xl\">\n                  Comunicamos con claridad el estado real de cada proceso, sus riesgos y sus costos. La confianza se construye sobre la honestidad, y esa es la base de toda relación con nuestros representados.\n                </p>\n              </div>\n            </div>\n          </article>\n          <article class=\"diff-block border-t border-(--copper)/40 pt-8\">\n            <div class=\"flex items-start gap-4 sm:gap-6\">\n              <span class=\"font-serif text-(--rose-light) text-xl sm:text-2xl leading-none mt-1\">03</span>\n              <div>\n                <h3 class=\"font-serif text-[clamp(1.25rem,4.5vw,1.6rem)] text-(--rose-dark) mb-3\">Resultados comprobados</h3>\n                <p class=\"text-(--gray-text) text-[15px] leading-relaxed max-w-xl\">\n                  Más de dos décadas de sentencias favorables y acuerdos exitosos respaldan nuestro trabajo. Medimos nuestro éxito por la tranquilidad que devolvemos a quienes confían en nosotros.\n                </p>\n              </div>\n            </div>\n          </article>\n          <article class=\"diff-block border-t border-(--copper)/40 pt-8\">\n            <div class=\"flex items-start gap-4 sm:gap-6\">\n              <span class=\"font-serif text-(--rose-light) text-xl sm:text-2xl leading-none mt-1\">04</span>\n              <div>\n                <h3 class=\"font-serif text-[clamp(1.25rem,4.5vw,1.6rem)] text-(--rose-dark) mb-3\">Cobertura nacional</h3>\n                <p class=\"text-(--gray-text) text-[15px] leading-relaxed max-w-xl\">\n                  Con presencia y red de contactos a lo largo de todo Chile, representamos a nuestros clientes ante tribunales de cualquier región, garantizando una defensa cercana sin importar la distancia.\n                </p>\n              </div>\n            </div>\n          </article>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"bg-(--white) py-16 sm:py-20 lg:py-28 border-y border-(--beige-dark)/25\">\n    <div class=\"mx-auto max-w-360 px-6 sm:px-14 lg:px-24\">\n      <div class=\"flex flex-col md:flex-row md:items-end justify-between mb-16 gap-6\">\n        <div>\n          <p class=\"text-(--copper) text-xs tracking-[0.22em] sm:tracking-[0.35em] uppercase font-semibold mb-5\">El Equipo</p>\n          <h2 class=\"font-serif text-[clamp(2rem,7vw,2.8rem)] leading-tight text-(--charcoal)\">Quienes <span class=\"italic text-(--rose-dark)\">defienden</span> por usted</h2>\n        </div>\n        <p class=\"text-(--gray-text) text-[15px] leading-relaxed max-w-sm md:text-right\">\n          Un equipo multidisciplinario de abogados y abogadas comprometidos con la excelencia jurídica.\n        </p>\n      </div>\n\n      <div class=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-x-8 gap-y-14\">\n        \n        <div class=\"team-card text-center\">\n          <div class=\"relative inline-block mb-6\">\n            <div class=\"w-44 h-44 rounded-full p-0.75 ring-1 ring-(--rose-dark) ring-offset-4 ring-offset-(--white)\">\n              <img src=\"img/silueta-hombre.jpg\" alt=\"Foto próximamente\" decoding=\"async\" loading=\"lazy\" class=\"w-full h-full object-cover rounded-full\" width=\"176\" height=\"176\">\n            </div>\n          </div>\n          <h3 class=\"font-serif text-[1.35rem] text-(--charcoal)\">Próximamente</h3>\n          <p class=\"text-(--copper) text-xs tracking-[0.15em] uppercase font-semibold mt-1 mb-3\">Próximamente</p>\n          <p class=\"text-(--gray-text) text-[13.5px] leading-relaxed px-2\">Próximamente</p>\n        </div>\n        \n        <div class=\"team-card text-center\">\n          <div class=\"relative inline-block mb-6\">\n            <div class=\"w-44 h-44 rounded-full p-0.75 ring-1 ring-(--rose-dark) ring-offset-4 ring-offset-(--white)\">\n              <img src=\"img/silueta-mujer.png\" alt=\"Foto próximamente\" decoding=\"async\" loading=\"lazy\" class=\"w-full h-full object-cover rounded-full\" width=\"176\" height=\"176\">\n            </div>\n          </div>\n          <h3 class=\"font-serif text-[1.35rem] text-(--charcoal)\">Próximamente</h3>\n          <p class=\"text-(--copper) text-xs tracking-[0.15em] uppercase font-semibold mt-1 mb-3\">Próximamente</p>\n          <p class=\"text-(--gray-text) text-[13.5px] leading-relaxed px-2\">Próximamente</p>\n        </div>\n        \n        <div class=\"team-card text-center\">\n          <div class=\"relative inline-block mb-6\">\n            <div class=\"w-44 h-44 rounded-full p-0.75 ring-1 ring-(--rose-dark) ring-offset-4 ring-offset-(--white)\">\n              <img src=\"img/silueta-mujer.png\" alt=\"Foto próximamente\" decoding=\"async\" loading=\"lazy\" class=\"w-full h-full object-cover rounded-full\" width=\"176\" height=\"176\">\n            </div>\n          </div>\n          <h3 class=\"font-serif text-[1.35rem] text-(--charcoal)\">Próximamente</h3>\n          <p class=\"text-(--copper) text-xs tracking-[0.15em] uppercase font-semibold mt-1 mb-3\">Próximamente</p>\n          <p class=\"text-(--gray-text) text-[13.5px] leading-relaxed px-2\">Próximamente</p>\n        </div>\n        \n        <div class=\"team-card text-center\">\n          <div class=\"relative inline-block mb-6\">\n            <div class=\"w-44 h-44 rounded-full p-0.75 ring-1 ring-(--rose-dark) ring-offset-4 ring-offset-(--white)\">\n              <img src=\"img/silueta-hombre.jpg\" alt=\"Foto próximamente\" decoding=\"async\" loading=\"lazy\" class=\"w-full h-full object-cover rounded-full\" width=\"176\" height=\"176\">\n            </div>\n          </div>\n          <h3 class=\"font-serif text-[1.35rem] text-(--charcoal)\">Próximamente</h3>\n          <p class=\"text-(--copper) text-xs tracking-[0.15em] uppercase font-semibold mt-1 mb-3\">Próximamente</p>\n          <p class=\"text-(--gray-text) text-[13.5px] leading-relaxed px-2\">Próximamente</p>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"bg-(--beige-main) py-16 sm:py-20 lg:py-28\">\n    <div class=\"max-w-225 mx-auto px-5 sm:px-6 lg:px-8 text-center\">\n      <span class=\"font-serif text-(--rose-light) text-[clamp(3.5rem,15vw,6rem)] leading-[0.5] block mb-2\">&ldquo;</span>\n      <blockquote class=\"font-serif italic text-(--charcoal) text-[clamp(1.6rem,3vw,2.6rem)] leading-[1.35]\">\n        Nuestra misión no es solo ganar casos, sino restituir la tranquilidad de quienes nos confían sus asuntos más importantes. Ahí reside la verdadera justicia.\n      </blockquote>\n      <div class=\"mt-10 flex flex-col sm:flex-row items-center justify-center gap-3 sm:gap-4\">\n        <span class=\"hidden sm:block w-6 sm:w-10 h-px bg-(--copper)\"></span>\n        <p class=\"text-(--gray-text) text-[13px] tracking-[0.15em] uppercase\">Próximamente</p>\n        <span class=\"hidden sm:block w-6 sm:w-10 h-px bg-(--copper)\"></span>\n      </div>\n    </div>\n  </section>\n\n  \n  ",
